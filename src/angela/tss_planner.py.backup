MAX_RANGE_DAYS = 45
MAX_CHUNK_DAYS = 45

CTL_TAU = 42
ATL_TAU = 7
HISTORY_DAYS = max(365, 5 * CTL_TAU)


import math
from datetime import date, timedelta


def ewma(vals, tau, seed_with_first=True):
    """Calculate EWMA values"""
    alpha = 1 - math.exp(-1.0 / tau)
    y = []
    if not vals:
        return y
    prev = vals[0] if seed_with_first else 0.0
    prev = prev + alpha * (vals[0] - prev)
    y.append(prev)
    for x in vals[1:]:
        prev = prev + alpha * (x - prev)
        y.append(prev)
    return y


def normalize_sport(workout, target_sport):
    """Normalize sport type"""
    sport_raw = workout.get("WorkoutType") or ""
    sport = sport_raw.strip().lower()
    if target_sport == "run" and "run" in sport:
        return True
    if target_sport == "bike" and ("bike" in sport or "mtb" in sport):
        return True
    return False


def get_next_sunday(from_date=None):
    """Get the coming Sunday from a given date"""
    if from_date is None:
        from_date = date.today()

    days_until_sunday = (6 - from_date.weekday()) % 7
    if days_until_sunday == 0:
        days_until_sunday = 7
    return from_date + timedelta(days=days_until_sunday)


def get_wednesday_before_sunday(sunday_date):
    """Get wednesday before the given Sunday"""
    return sunday_date - timedelta(days=4)


def find_score_in_range(value, ranges):
    """Find score based on value in renges."""
    for item in ranges:
        if item["low"] <= value <= item["high"]:
            return item["value"]
    return 0


def find_score_by_string(string_val, items, key="we_str"):
    """Find score by string match"""
    for item in items:
        if item.get(key) == string_val:
            return item["value"]
    return 0


@dashboard_bp.route("/api/training-stress-recommendation", methods=["POST"])
def training_stress_recommendation():
    """Calculate training stress recommendation (Bike + Run, with orthopedic scoring for Run only)."""
    try:
        data = request.get_json(silent=True) or {}
        print("DATA ====>", data)

        # Extract inputs
        athlete_id = data.get("selected_athlete")
        sport_type = data.get("sport_type")  # 'run' or 'bike'
        block_type = data.get("block_type")
        key_workouts = data.get("key_workouts")
        soreness = data.get("soreness")
        mood_irritability = data.get("mood_irritability")
        sleep = data.get("sleep")
        hrv_rhr = data.get("hrv_rhr")
        motivation = data.get("motivation")
        life_stress = data.get("life_stress")
        orthopedic_flags = data.get("orthopedic_flags")  # Only relevant for Run

        # Validation
        if not athlete_id:
            return jsonify({"error": "No athlete selected"}), 400

        required_fields = [
            block_type,
            sport_type,
            key_workouts,
            soreness,
            mood_irritability,
            sleep,
            hrv_rhr,
            motivation,
            life_stress,
        ]
        if not all(required_fields):
            return jsonify({"error": "Missing required fields"}), 400

        if sport_type not in BLOCK_CONFIGS:
            return jsonify({"error": "Invalid sport type"}), 400

        if block_type not in BLOCK_CONFIGS[sport_type]:
            return (
                jsonify({"error": f"Invalid block type for sport: {sport_type}"}),
                400,
            )

        # Select block config based on sport
        config = BLOCK_CONFIGS[sport_type][block_type]

        # Calculate key dates
        today = date.today()
        coming_sunday = get_next_sunday(today)
        mid_week_wednesday = get_wednesday_before_sunday(coming_sunday)

        # Fetch workouts within range
        fetch_from = today - timedelta(days=HISTORY_DAYS)
        fetch_to = coming_sunday
        workouts = []
        current_start = fetch_from

        while current_start <= fetch_to:
            current_end = min(
                current_start + timedelta(days=MAX_CHUNK_DAYS - 1), fetch_to
            )
            api_url = f'/v2/workouts/{athlete_id}/{current_start.strftime("%Y-%m-%d")}/{current_end.strftime("%Y-%m-%d")}'

            try:
                result = tp_request(endpoint=api_url, method="GET")
                result.raise_for_status()
                chunk_data = result.json() or []
                workouts.extend(chunk_data)
            except requests.RequestException as e:
                return jsonify({"error": f"Failed to fetch workouts: {str(e)}"}), 502

            current_start = current_end + timedelta(days=1)

        # Aggregate TSS data
        daily = defaultdict(lambda: {"actual": 0.0, "planned": 0.0})
        for w in workouts:
            try:
                day_str = w.get("WorkoutDay")
                if not day_str:
                    continue

                d = date.fromisoformat(day_str.split("T")[0])
                if d < fetch_from or d > fetch_to:
                    continue

                if not normalize_sport(w, sport_type):
                    continue

                tss_actual = float(w.get("TssActual") or 0.0)
                tss_planned = float(w.get("TssPlanned") or 0.0)
                completed = bool(w.get("Completed") or False)

                if completed:
                    daily[d]["actual"] += tss_actual
                    daily[d]["planned"] += tss_planned
                else:
                    daily[d]["planned"] += tss_planned
            except Exception:
                continue

        # Build daily TSS series
        all_days = []
        tss_values = []
        d = fetch_from

        while d <= fetch_to:
            all_days.append(d)
            entry = daily.get(d, {"actual": 0.0, "planned": 0.0})
            if d < today:
                tss_val = entry.get("actual", 0.0)
            else:
                tss_val = entry.get("planned", 0.0)
            tss_values.append(tss_val)
            d += timedelta(days=1)

        # Compute CTL / ATL / TSB
        ctl_values = ewma(tss_values, CTL_TAU, seed_with_first=True)
        atl_values = ewma(tss_values, ATL_TAU, seed_with_first=True)

        tsb_values = [None]
        for i in range(1, len(ctl_values)):
            tsb_values.append(ctl_values[i - 1] - atl_values[i - 1])

        # Sunday and Wednesday values
        sunday_idx = (coming_sunday - fetch_from).days
        wednesday_idx = (mid_week_wednesday - fetch_from).days

        ctl_sunday = ctl_values[sunday_idx]
        atl_sunday = atl_values[sunday_idx]
        wtsb = tsb_values[wednesday_idx] if wednesday_idx < len(tsb_values) else 0

        # Derived metrics
        echo_estimate = (7 * ctl_sunday) / 0.965
        eow_tsb = ctl_sunday - atl_sunday
        tsb_slope_5d = (wtsb - eow_tsb) / 5
        atl_ctl_ratio = atl_sunday / ctl_sunday if ctl_sunday != 0 else 0

        # Component scores
        atl_ctl_score = find_score_in_range(atl_ctl_ratio, config["atl_ctl_ratio"])
        tsb_trend_score = find_score_in_range(tsb_slope_5d, config["5_day_tsb_trend"])
        eow_tsb_score = find_score_in_range(eow_tsb, config["EowTSB"])
        workout_execution_score = find_score_by_string(
            key_workouts, config["workout_execution"], "we_str"
        )

        # Subjective metrics
        subjective_total = (
            COMMON_OPTIONS.get(soreness, 0)
            + COMMON_OPTIONS.get(mood_irritability, 0)
            + COMMON_OPTIONS.get(sleep, 0)
            + COMMON_OPTIONS.get(hrv_rhr, 0)
            + COMMON_OPTIONS.get(motivation, 0)
        )
        subjective_score = find_score_in_range(
            subjective_total, config["subjective_scoring"]
        )

        # Life stress
        life_stress_score = find_score_by_string(
            life_stress, config["life_stress_scoring"], "ls_str"
        )

        # Orthopedic flags — only for Run
        orthopedic_score = 0
        if sport_type == "run" and orthopedic_flags:
            orthopedic_score = find_score_by_string(
                orthopedic_flags, config.get("orthopedic_flags_scoring", []), "of_str"
            )

        # Combine total
        overall_score = (
            atl_ctl_score
            + tsb_trend_score
            + eow_tsb_score
            + workout_execution_score
            + subjective_score
            + life_stress_score
            + orthopedic_score  # include only for run
        )

        # Find recommendation
        recommendation_data = next(
            (
                rec
                for rec in config["training_stress_recommendation_scale"]
                if rec["low"] <= overall_score <= rec["high"]
            ),
            None,
        )

        if not recommendation_data:
            return jsonify({"error": "Could not determine recommendation"}), 500

        # Compute percent change
        low_change = recommendation_data["low_change"]
        high_change = recommendation_data["high_change"]
        percentage_change = ((low_change + high_change) / 2) - 1

        # Final response
        return jsonify(
            {
                "status": "ok",
                "ctl": int(round(ctl_sunday)),
                "atl": int(round(atl_sunday)),
                "wtsb": int(round(wtsb)),
                "echo_estimate": int(round(echo_estimate)),
                "eow_tsb": int(round(eow_tsb)),
                "tsb_slope_5d": int(round(tsb_slope_5d)),
                "atl_ctl_ratio": round(atl_ctl_ratio, 4),
                "overall_score": int(round(overall_score)),
                "recommendation": recommendation_data["recommendation"],
                "percentage_change": int(round(percentage_change * 100)),
                "coming_sunday": coming_sunday.strftime("%Y-%m-%d"),
                "mid_week_wednesday": mid_week_wednesday.strftime("%Y-%m-%d"),
                "orthopedic_score": orthopedic_score if sport_type == "run" else None,
                "low_change": recommendation_data["low_change"],
                "high_change": recommendation_data["high_change"],
            }
        )

    except Exception as e:
        print("Error:", e)
        return jsonify({"error": f"Unexpected server error: {str(e)}"}), 500