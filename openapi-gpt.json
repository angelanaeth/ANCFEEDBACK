{
  "openapi": "3.1.0",
  "info": {
    "title": "Angela Coach API",
    "description": "AI-powered endurance coaching with TrainingPeaks and Intervals.icu integration. Provides CTL/ATL/TSB analysis, stress state classification, and automated training recommendations.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://angela-coach.pages.dev",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/gpt/athlete-data": {
      "post": {
        "operationId": "getAthleteData",
        "summary": "Get athlete training data and metrics",
        "description": "Fetches comprehensive athlete data including CTL, ATL, TSB, workouts, and wellness metrics from TrainingPeaks or Intervals.icu",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "athleteId": {
                    "type": "string",
                    "description": "Athlete ID (TrainingPeaks ID or Intervals.icu ID with 'i' prefix)"
                  },
                  "dataSource": {
                    "type": "string",
                    "enum": ["trainingpeaks", "intervals"],
                    "default": "intervals",
                    "description": "Data source to use"
                  }
                },
                "required": ["athleteId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Athlete data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dataSource": {
                      "type": "string"
                    },
                    "athlete": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "name": { "type": "string" },
                        "email": { "type": "string" }
                      }
                    },
                    "metrics": {
                      "type": "object",
                      "properties": {
                        "ctl": { "type": "number", "description": "Chronic Training Load (42-day)" },
                        "atl": { "type": "number", "description": "Acute Training Load (7-day)" },
                        "tsb": { "type": "number", "description": "Training Stress Balance" }
                      }
                    },
                    "stressState": {
                      "type": "object",
                      "properties": {
                        "state": { "type": "string", "enum": ["Compromised", "Overreached", "Productive Fatigue", "Recovered", "Detraining"] },
                        "intensity": { "type": "number" },
                        "recommendation": { "type": "string" }
                      }
                    },
                    "workouts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string" },
                          "date": { "type": "string" },
                          "name": { "type": "string" },
                          "tss": { "type": "number" },
                          "duration": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt/recommend": {
      "post": {
        "operationId": "generateRecommendation",
        "summary": "Generate training recommendation",
        "description": "Generates intelligent training recommendations based on current stress state, block type, and training history using Angela's coaching algorithms",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "athleteId": {
                    "type": "string",
                    "description": "Athlete ID"
                  },
                  "blockType": {
                    "type": "string",
                    "enum": ["base_durability", "build_th", "vo2_max", "specificity", "hybrid", "rebuild"],
                    "description": "Current training block type"
                  },
                  "currentWeekTSS": {
                    "type": "number",
                    "description": "Current week's total TSS"
                  }
                },
                "required": ["athleteId", "blockType", "currentWeekTSS"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Training recommendation generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "athleteId": { "type": "string" },
                    "currentMetrics": {
                      "type": "object",
                      "properties": {
                        "ctl": { "type": "number" },
                        "atl": { "type": "number" },
                        "tsb": { "type": "number" }
                      }
                    },
                    "stressState": { "type": "string" },
                    "recommendation": { "type": "string" },
                    "weeklyPlan": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "day": { "type": "number" },
                          "dayName": { "type": "string" },
                          "tss": { "type": "number" }
                        }
                      }
                    },
                    "reasoning": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt/post-workout": {
      "post": {
        "operationId": "postWorkout",
        "summary": "Post planned workout",
        "description": "Creates a planned workout in TrainingPeaks or Intervals.icu calendar",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "athleteId": {
                    "type": "string",
                    "description": "Athlete ID"
                  },
                  "dataSource": {
                    "type": "string",
                    "enum": ["trainingpeaks", "intervals"],
                    "description": "Platform to post to"
                  },
                  "workout": {
                    "type": "object",
                    "properties": {
                      "date": { "type": "string", "format": "date" },
                      "title": { "type": "string" },
                      "description": { "type": "string" },
                      "tss": { "type": "number" },
                      "duration": { "type": "number", "description": "Duration in minutes" },
                      "type": { "type": "string", "enum": ["bike", "run", "swim"] }
                    },
                    "required": ["date", "title", "tss", "duration", "type"]
                  }
                },
                "required": ["athleteId", "dataSource", "workout"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workout posted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "dataSource": { "type": "string" },
                    "workout": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
