  // Initialize charts (if Chart.js is available)
  if (typeof Chart !== 'undefined') {
    initLT1Charts(analysis);
  }
}

// Initialize Chart.js charts
function initLT1Charts(analysis) {
  // Power & HR Progression Chart
  const powerCtx = document.getElementById('lt1-chart-power');
  if (powerCtx && !powerCtx._chartInitialized) {
    powerCtx._chartInitialized = true;
    new Chart(powerCtx, {
      type: 'line',
      data: {
        labels: analysis.stages.map(s => `Stage ${s.num}`),
        datasets: [
          {
            label: 'Power (W)',
            data: analysis.stages.map(s => s.power),
            borderColor: '#2563eb',
            backgroundColor: 'rgba(37,99,235,0.1)',
            yAxisID: 'y'
          },
          {
            label: 'Heart Rate (bpm)',
            data: analysis.stages.map(s => s.hr),
            borderColor: '#dc2626',
            backgroundColor: 'rgba(220,38,38,0.1)',
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        scales: {
          y: { type: 'linear', display: true, position: 'left', title: { display: true, text: 'Power (W)' } },
          y1: { type: 'linear', display: true, position: 'right', title: { display: true, text: 'HR (bpm)' }, grid: { drawOnChartArea: false } }
        }
      }
    });
  }

  // HR Delta Analysis Chart
  const deltaCtx = document.getElementById('lt1-chart-delta');
  if (deltaCtx && !deltaCtx._chartInitialized) {
    deltaCtx._chartInitialized = true;
    new Chart(deltaCtx, {
      type: 'bar',
      data: {
        labels: analysis.stages.map(s => `Stage ${s.num}`),
        datasets: [{
          label: 'HR Delta',
          data: analysis.stages.map(s => s.hrDelta),
          backgroundColor: analysis.stages.map(s => 
            s.hrDelta > 6 ? '#dc2626' : s.hrDelta > 4 ? '#f59e0b' : '#16a34a'
          )
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, title: { display: true, text: 'HR Delta (bpm)' } }
        }
      }
    });
  }
}

// Export PDF with selected logo
async function exportLT1PDF() {
  if (!lt1Analysis) {
    alert('Please upload and analyze a file first');
    return;
  }

  if (typeof jspdf === 'undefined' || !jspdf.jsPDF) {
    alert('PDF library not loaded. Please refresh the page.');
    return;
  }

  const { jsPDF } = jspdf;
  const doc = new jsPDF();
  
  const athleteName = document.getElementById('lt1-athlete-name').value || 'Athlete';
  const testDate = document.getElementById('lt1-test-date').value || new Date().toISOString().split('T')[0];
  const logoSelect = document.getElementById('pdf-logo-lt1');
  const selectedLogo = logoSelect ? logoSelect.value : 'echodevo';

  // Add logo (if URL is available)
  const logoUrl = LT1_LOGOS[selectedLogo];
  if (logoUrl) {
    try {
      const img = await loadImage(logoUrl);
      doc.addImage(img, 'PNG', 14, 10, 40, 14);
    } catch (e) {
      console.warn('Could not load logo:', e);
    }
  }

  // Title
  doc.setFontSize(20);
  doc.setFont('helvetica', 'bold');
  doc.text('LT1/OGC Threshold Analysis Report', 14, logoUrl ? 35 : 20);
  
  // Athlete info
  doc.setFontSize(11);
  doc.setFont('helvetica', 'normal');
  doc.text(`Athlete: ${athleteName}`, 14, logoUrl ? 45 : 30);
  doc.text(`Test Date: ${testDate}`, 14, logoUrl ? 52 : 37);
  
  // Summary section
  doc.setFontSize(14);
  doc.setFont('helvetica', 'bold');
  doc.text('Threshold Summary', 14, logoUrl ? 65 : 50);
  
  doc.setFontSize(10);
  doc.setFont('helvetica', 'normal');
  let yPos = logoUrl ? 73 : 58;
  doc.text(`LT1 Power: ${lt1Analysis.lt1.power} W (${lt1Analysis.lt1.percentCP}% CP)`, 14, yPos);
  doc.text(`LT1 Heart Rate: ${lt1Analysis.lt1.hr} bpm`, 14, yPos + 6);
  doc.text(`OGC Power: ${lt1Analysis.ogc.power} W (${lt1Analysis.ogc.percentCP}% CP)`, 14, yPos + 12);
  doc.text(`OGC Heart Rate: ${lt1Analysis.ogc.hr} bpm`, 14, yPos + 18);
  doc.text(`Aerobic Window: ${lt1Analysis.aerobicWindow} W`, 14, yPos + 24);

  // Training zones
  doc.setFontSize(14);
  doc.setFont('helvetica', 'bold');
  doc.text('Training Zones', 14, yPos + 38);
  
  doc.setFontSize(9);
  doc.setFont('helvetica', 'normal');
  yPos += 46;
  doc.text(`Recovery: <${Math.round(lt1Analysis.lt1.power * 0.85)} W (<${Math.round(lt1Analysis.lt1.percentCP * 0.85)}% CP)`, 14, yPos);
  doc.text(`Endurance (Z1): ${Math.round(lt1Analysis.lt1.power * 0.85)}-${lt1Analysis.lt1.power} W (${Math.round(lt1Analysis.lt1.percentCP * 0.85)}-${lt1Analysis.lt1.percentCP}% CP)`, 14, yPos + 6);
  doc.text(`Tempo (Z2): ${lt1Analysis.lt1.power}-${lt1Analysis.ogc.power} W (${lt1Analysis.lt1.percentCP}-${lt1Analysis.ogc.percentCP}% CP)`, 14, yPos + 12);
  doc.text(`Sweet Spot: ${lt1Analysis.ogc.power}-${Math.round(lt1Analysis.cp * 0.95)} W (${lt1Analysis.ogc.percentCP}-95% CP)`, 14, yPos + 18);
  doc.text(`Threshold: ${Math.round(lt1Analysis.cp * 0.95)}-${lt1Analysis.cp} W (95-100% CP)`, 14, yPos + 24);

  // Stage breakdown table
  doc.setFontSize(14);
  doc.setFont('helvetica', 'bold');
  doc.text('Stage Breakdown', 14, yPos + 38);

  doc.setFontSize(8);
  doc.setFont('helvetica', 'bold');
  yPos += 46;
  doc.text('#', 14, yPos);
  doc.text('Power', 24, yPos);
  doc.text('% CP', 44, yPos);
  doc.text('HR', 64, yPos);
  doc.text('% HRR', 84, yPos);
  doc.text('HR Δ', 104, yPos);
  doc.text('Zone', 124, yPos);

  doc.setFont('helvetica', 'normal');
  lt1Analysis.stages.forEach((stage, index) => {
    yPos += 6;
    if (yPos > 270) {
      doc.addPage();
      yPos = 20;
    }
    doc.text(stage.num.toString(), 14, yPos);
    doc.text(`${stage.power} W`, 24, yPos);
    doc.text(`${stage.percentCP}%`, 44, yPos);
    doc.text(`${stage.hr}`, 64, yPos);
    doc.text(`${stage.percentHRR}%`, 84, yPos);
    doc.text(`${stage.hrDelta}`, 104, yPos);
    doc.text(stage.zone, 124, yPos);
  });

  // Save PDF
  doc.save(`LT1-OGC-Analysis_${athleteName.replace(/\s+/g, '-')}_${testDate}.pdf`);
}

// Helper to load image
function loadImage(url) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => resolve(img);
    img.onerror = reject;
    img.src = url;
  });
}

// Initialize when tab is opened
document.addEventListener('DOMContentLoaded', () => {
  // Wait a bit for tab system to initialize
  setTimeout(() => {
    const tab = document.querySelector('[data-tab="lt1-ogc"]');
    if (tab) {
      tab.addEventListener('click', () => {
        setTimeout(initLT1Calculator, 100);
      });
    }
    // Also init if already on this tab
    const panel = document.getElementById('tab-lt1-ogc');
    if (panel && panel.style.display !== 'none') {
      initLT1Calculator();
    }
  }, 500);
});
