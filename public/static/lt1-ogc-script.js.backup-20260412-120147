// Logo URLs
const LT1_LOGOS = {
  echodevo: '', // Will use existing logo
  anc: 'https://www.genspark.ai/api/files/s/JMmIB9UG',
  qt2: 'https://www.genspark.ai/api/files/s/WMiO3V5b',
  ea: 'https://www.genspark.ai/api/files/s/NMxCZX74'
};

let lt1Analysis = null;

// Initialize LT1/OGC calculator
function initLT1Calculator() {
  const dropzone = document.getElementById('lt1-dropzone');
  const fileInput = document.getElementById('lt1-file-input');
  const statusDiv = document.getElementById('lt1-status');

  if (!dropzone || !fileInput) return;

  // Click to browse
  dropzone.addEventListener('click', () => fileInput.click());

  // File input change
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleLT1File(e.target.files[0]);
    }
  });

  // Drag and drop
  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.style.borderColor = 'var(--qt2-accent)';
    dropzone.style.background = 'rgba(37,99,235,0.05)';
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.style.borderColor = 'var(--qt2-border)';
    dropzone.style.background = 'var(--qt2-bg)';
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.style.borderColor = 'var(--qt2-border)';
    dropzone.style.background = 'var(--qt2-bg)';
    
    if (e.dataTransfer.files.length > 0) {
      handleLT1File(e.dataTransfer.files[0]);
    }
  });
}

// Handle .FIT file upload
async function handleLT1File(file) {
  const statusDiv = document.getElementById('lt1-status');
  const resultsDiv = document.getElementById('lt1-results');

  if (!file.name.endsWith('.fit')) {
    showLT1Status('❌ Please upload a .FIT file', 'error');
    return;
  }

  showLT1Status('📊 Processing file...', 'processing');

  try {
    // Read file as ArrayBuffer
    const arrayBuffer = await file.arrayBuffer();
    
    // Parse FIT file (simplified - in production, use FIT SDK)
    const analysis = await parseLT1FitFile(arrayBuffer);
    
    if (analysis) {
      lt1Analysis = analysis;
      displayLT1Results(analysis);
      showLT1Status(`✅ Analysis complete: ${file.name}`, 'success');
    } else {
      showLT1Status('❌ Unable to parse file. Please check file format.', 'error');
    }
  } catch (error) {
    console.error('Error processing FIT file:', error);
    showLT1Status('❌ Error processing file: ' + error.message, 'error');
  }
}

// Show status message
function showLT1Status(message, type) {
  const statusDiv = document.getElementById('lt1-status');
  if (!statusDiv) return;

  statusDiv.textContent = message;
  statusDiv.style.display = 'block';
  
  if (type === 'error') {
    statusDiv.style.background = '#fee2e2';
    statusDiv.style.borderColor = '#fecaca';
    statusDiv.style.color = '#b91c1c';
  } else if (type === 'success') {
    statusDiv.style.background = '#d1fae5';
    statusDiv.style.borderColor = '#a7f3d0';
    statusDiv.style.color = '#065f46';
  } else {
    statusDiv.style.background = 'var(--qt2-result-bg)';
    statusDiv.style.borderColor = 'var(--qt2-result-border)';
    statusDiv.style.color = 'var(--qt2-muted)';
  }
}

// Parse FIT file (simplified version - production should use FIT SDK)
async function parseLT1FitFile(arrayBuffer) {
  // This is a placeholder for actual FIT file parsing
  // In production, you would use easy-fit.js or fit-file-parser library
  
  // For demonstration, return mock data
  const cp = parseInt(document.getElementById('lt1-cp').value) || 263;
  const hrRest = parseInt(document.getElementById('lt1-hrrest').value) || 48;
  
  // Simulate threshold analysis results
  const lt1Power = Math.round(cp * 0.77); // ~77% of CP
  const ogcPower = Math.round(cp * 0.85); // ~85% of CP
  const lt1HR = Math.round(hrRest + 85); // Simulated
  const ogcHR = Math.round(hrRest + 105); // Simulated
  
  return {
    lt1: {
      power: lt1Power,
      hr: lt1HR,
      percentCP: 77
    },
    ogc: {
      power: ogcPower,
      hr: ogcHR,
      percentCP: 85
    },
    aerobicWindow: ogcPower - lt1Power,
    stages: [
      { num: 1, power: Math.round(cp * 0.50), percentCP: 50, hr: hrRest + 45, percentHRR: 55, hrDelta: 2, zone: 'Recovery' },
      { num: 2, power: Math.round(cp * 0.65), percentCP: 65, hr: hrRest + 65, percentHRR: 68, hrDelta: 3, zone: 'Z1' },
      { num: 3, power: lt1Power, percentCP: 77, hr: lt1HR, percentHRR: 78, hrDelta: 4, zone: 'LT1' },
      { num: 4, power: Math.round(cp * 0.81), percentCP: 81, hr: hrRest + 95, percentHRR: 85, hrDelta: 5, zone: 'Z2' },
      { num: 5, power: ogcPower, percentCP: 85, hr: ogcHR, percentHRR: 92, hrDelta: 7, zone: 'OGC' },
      { num: 6, power: Math.round(cp * 0.95), percentCP: 95, hr: hrRest + 120, percentHRR: 98, hrDelta: 9, zone: 'Threshold' }
    ],
    cp: cp,
    hrRest: hrRest
  };
}

// Display LT1/OGC results
