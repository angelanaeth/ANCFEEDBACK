  document.getElementById('lt1-power-val').textContent = analysis.lt1.power;
  document.getElementById('lt1-hr-val').textContent = analysis.lt1.hr;
  document.getElementById('ogc-power-val').textContent = analysis.ogc.power;
  document.getElementById('ogc-hr-val').textContent = analysis.ogc.hr;
  document.getElementById('aero-window-val').textContent = analysis.aerobicWindow;

  // Display training zones
  const zonesOutput = document.getElementById('lt1-zones-output');
  zonesOutput.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;">
      <div style="padding:12px;background:#f0f9ff;border-left:3px solid #2563eb;border-radius:6px;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#1e40af;font-weight:600;margin-bottom:4px;">Recovery</div>
        <div style="font-size:18px;font-weight:700;color:#1e40af;">&lt;${Math.round(analysis.lt1.power * 0.85)} W</div>
        <div style="font-size:11px;color:#64748b;margin-top:2px;">&lt;${Math.round(analysis.lt1.percentCP * 0.85)}% CP</div>
      </div>
      <div style="padding:12px;background:#dcfce7;border-left:3px solid #16a34a;border-radius:6px;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#15803d;font-weight:600;margin-bottom:4px;">Endurance (Z1)</div>
        <div style="font-size:18px;font-weight:700;color:#15803d;">${Math.round(analysis.lt1.power * 0.85)}-${analysis.lt1.power} W</div>
        <div style="font-size:11px;color:#64748b;margin-top:2px;">${Math.round(analysis.lt1.percentCP * 0.85)}-${analysis.lt1.percentCP}% CP</div>
      </div>
      <div style="padding:12px;background:#fef3c7;border-left:3px solid #b06a14;border-radius:6px;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#b06a14;font-weight:600;margin-bottom:4px;">Tempo (Z2)</div>
        <div style="font-size:18px;font-weight:700;color:#b06a14;">${analysis.lt1.power}-${analysis.ogc.power} W</div>
        <div style="font-size:11px;color:#64748b;margin-top:2px;">${analysis.lt1.percentCP}-${analysis.ogc.percentCP}% CP</div>
      </div>
      <div style="padding:12px;background:#fee2e2;border-left:3px solid #dc2626;border-radius:6px;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#b91c1c;font-weight:600;margin-bottom:4px;">Sweet Spot</div>
        <div style="font-size:18px;font-weight:700;color:#b91c1c;">${analysis.ogc.power}-${Math.round(analysis.cp * 0.95)} W</div>
        <div style="font-size:11px;color:#64748b;margin-top:2px;">${analysis.ogc.percentCP}-95% CP</div>
      </div>
      <div style="padding:12px;background:#fce7f3;border-left:3px solid #9333ea;border-radius:6px;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#7e22ce;font-weight:600;margin-bottom:4px;">Threshold</div>
        <div style="font-size:18px;font-weight:700;color:#7e22ce;">${Math.round(analysis.cp * 0.95)}-${analysis.cp} W</div>
        <div style="font-size:11px;color:#64748b;margin-top:2px;">95-100% CP</div>
      </div>
    </div>
  `;

  // Populate stage breakdown table
  const tableBody = document.getElementById('lt1-table-body');
  tableBody.innerHTML = analysis.stages.map(stage => `
    <tr>
      <td>${stage.num}</td>
      <td>${stage.power}</td>
      <td>${stage.percentCP}%</td>
      <td>${stage.hr}</td>
      <td>${stage.percentHRR}%</td>
      <td>${stage.hrDelta}</td>
      <td><span style="padding:2px 6px;border-radius:3px;font-size:11px;font-weight:500;background:rgba(37,99,235,0.1);color:#2563eb;">${stage.zone}</span></td>
