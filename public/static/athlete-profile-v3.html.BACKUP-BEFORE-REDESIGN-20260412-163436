<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Athlete Profile - EchoDevo Coach</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/axios@1.6.0/dist/axios.min.js"></script>
  <style>
    /* ========================================
       PROFESSIONAL COACHING DASHBOARD
       Flat, Clean, Data-First Design
       ======================================== */
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      /* Professional Color System */
      --primary: #2563eb;
      --primary-dark: #1e40af;
      --text-primary: #1f2937;
      --text-secondary: #6b7280;
      --text-muted: #9ca3af;
      --border: #e5e7eb;
      --border-light: #f3f4f6;
      --bg-gray: #f9fafb;
      --bg-white: #ffffff;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.5;
      color: var(--text-primary);
      background: var(--bg-gray);
    }
    
    /* ========================================
       HEADER / NAVBAR
       ======================================== */
    .top-bar {
      background: var(--bg-white);
      border-bottom: 1px solid #f0f0f0;
      padding: 0.25rem 24px;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
    }
    
    .logo-image {
      height: 224px;
      width: auto;
    }
    
    .top-bar .actions {
      position: absolute;
      right: 24px;
      display: flex;
      gap: 8px;
    }
    
    @media (max-width: 768px) {
      .top-bar {
        flex-direction: column;
        gap: 0.5rem;
      }
      
      .top-bar .actions {
        position: static;
        width: 100%;
        justify-content: center;
      }
      
      .logo-image {
        height: 160px;
      }
    }
    
    /* ========================================
       BUTTONS
       ======================================== */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      font-size: 13px;
      font-weight: 500;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg-white);
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.15s;
      text-decoration: none;
    }
    
    .btn:hover {
      background: var(--bg-gray);
      border-color: var(--text-secondary);
    }
    
    .btn-primary {
      background: var(--primary);
      border-color: var(--primary);
      color: white;
    }
    
    .btn-primary:hover {
      background: var(--primary-dark);
      border-color: var(--primary-dark);
      color: white;
    }
    
    .btn-sm {
      padding: 4px 8px;
      font-size: 12px;
    }
    
    /* ========================================
       LAYOUT
       ======================================== */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 24px;
    }
    
    .profile-header {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 16px 20px;
      margin-bottom: 20px;
    }
    
    .profile-header h2 {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 4px;
    }
    
    .profile-header .meta {
      font-size: 13px;
      color: var(--text-secondary);
    }
    
    /* ========================================
       TABS - WITH SPORT COLORS
       ======================================== */
    .tabs {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-bottom: none;
      display: flex;
      gap: 0;
    }
    
    .tab {
      padding: 12px 24px;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-secondary);
      background: transparent;
      border: 1px solid var(--border);
      border-bottom: 3px solid transparent;
      cursor: pointer;
      transition: all 0.15s;
      position: relative;
    }
    
    .tab:hover {
      color: var(--text-primary);
      background: var(--bg-gray);
      border-color: var(--gray-300);
    }
    
    .tab.active {
      color: var(--text-primary);
      font-weight: 600;
      background: white;
      border-bottom: 3px solid transparent;
    }
    
    /* Sport-specific tab colors */
    .tab[data-sport="swim"].active {
      border-bottom-color: #06b6d4;
      color: #0891b2;
    }
    
    .tab[data-sport="bike"].active {
      border-bottom-color: #f59e0b;
      color: #d97706;
    }
    
    .tab[data-sport="run"].active {
      border-bottom-color: #ef4444;
      color: #dc2626;
    }
    
    .tab-content {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-top: none;
      padding: 20px;
    }
    
    /* Tab pane visibility control */
    .tab-pane {
      display: none;
    }
    
    .tab-pane.show {
      display: block;
    }
    
    .tab-pane.active {
      display: block;
    }
    
    /* ========================================
       METRIC CARDS
       ======================================== */
    .metric-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 16px;
      margin-bottom: 16px;
    }
    
    .metric-label {
      font-size: 12px;
      font-weight: 500;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }
    
    .metric-value {
      font-size: 32px;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1;
    }
    
    .metric-source {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 4px;
    }
    
    /* ========================================
       TABLES - PROFESSIONAL DATA TABLES
       ======================================== */
    .data-table-container {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: 4px;
      margin-bottom: 20px;
      overflow: hidden;
    }
    
    .data-table-header {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      background: var(--bg-gray);
    }
    
    .data-table-header h3 {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
    }
    
    .data-table-header p {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 2px;
    }
    
    .data-table {
      width: 100%;
      border-collapse: collapse;
    }
    
    .data-table thead {
      background: var(--bg-gray);
      border-bottom: 1px solid var(--border);
    }
    
    .data-table th {
      padding: 8px 16px;
      text-align: left;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .data-table td {
      padding: 10px 16px;
      font-size: 14px;
      border-bottom: 1px solid var(--border-light);
    }
    
    .data-table tbody tr:last-child td {
      border-bottom: none;
    }
    
    .data-table tbody tr:hover {
      background: var(--bg-gray);
    }
    
    /* Table cell types */
    .data-table .zone-col {
      font-weight: 600;
      color: var(--primary);
      width: 60px;
    }
    
    .data-table .value-col {
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    
    .data-table .range-col {
      color: var(--text-secondary);
      font-size: 13px;
    }
    
    .data-table .editable {
      cursor: pointer;
      border-bottom: 1px dashed var(--border);
    }
    
    .data-table .editable:hover {
      background: var(--bg-gray);
      border-bottom-color: var(--primary);
    }
    
    /* ========================================
       FORMS
       ======================================== */
    .form-group {
      margin-bottom: 16px;
    }
    
    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 6px;
    }
    
    .form-control {
      width: 100%;
      padding: 8px 12px;
      font-size: 14px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg-white);
      transition: border-color 0.15s;
    }
    
    .form-control:focus {
      outline: none;
      border-color: var(--primary);
    }
    
    .form-hint {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 4px;
    }
    
    /* ========================================
       ALERTS
       ======================================== */
    .alert {
      padding: 12px 16px;
      border-radius: 4px;
      font-size: 13px;
      margin-bottom: 16px;
      border: 1px solid;
    }
    
    .alert-info {
      background: #eff6ff;
      border-color: #bfdbfe;
      color: #1e40af;
    }
    
    .alert-success {
      background: #f0fdf4;
      border-color: #bbf7d0;
      color: #15803d;
    }
    
    /* ========================================
       SECTION DIVIDERS
       ======================================== */
    .section-divider {
      border-top: 1px solid var(--border);
      margin: 24px 0;
    }
    
    /* ========================================
       UTILITY CLASSES
       ======================================== */
    .mb-2 { margin-bottom: 8px; }
    .mb-3 { margin-bottom: 16px; }
    .mb-4 { margin-bottom: 24px; }
    .mt-2 { margin-top: 8px; }
    .mt-3 { margin-top: 16px; }
    
    .text-muted { color: var(--text-muted); }
    .text-secondary { color: var(--text-secondary); }
    .text-center { text-align: center; }
    
    .d-flex { display: flex; }
    .gap-2 { gap: 8px; }
    .gap-3 { gap: 16px; }
    .justify-between { justify-content: space-between; }
    .align-center { align-items: center; }
    
    /* ========================================
       ATHLETE INFO CARD
       ======================================== */
    .athlete-info-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 16px 20px;
      margin-bottom: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .athlete-info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      flex: 1;
    }
    
    .info-item {
      font-size: 13px;
    }
    
    .info-label {
      color: var(--text-secondary);
      font-weight: 500;
      margin-bottom: 2px;
    }
    
    .info-value {
      color: var(--text-primary);
      font-weight: 500;
    }
    
    .mail-link {
      color: var(--text-secondary);
      text-decoration: none;
      margin-left: 8px;
      transition: color 0.15s;
    }
    
    .mail-link:hover {
      color: var(--primary);
    }
    
    /* ========================================
       MODAL
       ======================================== */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    
    .modal.show {
      display: flex;
    }
    
    .modal-dialog {
      background: var(--bg-white);
      border-radius: 4px;
      max-width: 600px;
      width: 90%;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      border: 3px solid #3b82f6;
      position: relative;
      pointer-events: auto;
    }
    
    .modal-header {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0;
    }
    
    .modal-header h3 {
      font-size: 16px;
      font-weight: 600;
      margin: 0;
    }
    
    .modal-close {
      background: none;
      border: none;
      font-size: 24px;
      color: var(--text-secondary);
      cursor: pointer;
      padding: 0;
      width: 32px;
      height: 32px;
      line-height: 1;
    }
    
    .modal-close:hover {
      color: var(--text-primary);
    }
    
    .modal-body {
      padding: 20px;
      overflow-y: auto;
      flex: 1;
    }
    
    .modal-footer {
      padding: 16px 20px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      flex-shrink: 0;
    }
    
    /* ========================================
       COLLAPSIBLE SECTION
       ======================================== */
    .collapsible-header {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: 4px 4px 0 0;
      padding: 12px 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      transition: background 0.15s;
    }
    
    .collapsible-header:hover {
      background: var(--bg-gray);
    }
    
    .collapsible-header h3 {
      font-size: 14px;
      font-weight: 600;
      margin: 0;
    }
    
    .collapsible-toggle {
      color: var(--text-secondary);
      font-size: 12px;
      transition: transform 0.2s;
    }
    
    .collapsible-toggle.open {
      transform: rotate(180deg);
    }
    
    .collapsible-content {
      border: 1px solid var(--border);
      border-top: none;
      border-radius: 0 0 4px 4px;
      background: var(--bg-white);
    }
    
    .collapsible-content.collapsed {
      display: none;
    }
    @media (max-width: 768px) {
      .container {
        padding: 16px;
        max-width: 100%;
        overflow-x: hidden;
      }
      
      .metric-value {
        font-size: 24px;
      }
      
      .data-table th,
      .data-table td {
        padding: 8px 12px;
        font-size: 13px;
      }
      
      .border-box {
        overflow-x: auto;
      }
      
      table {
        min-width: 600px;
      }
    }
  </style>
</head>
<body>

  <!-- Professional Top Bar -->
  <div class="top-bar">
    <img src="/static/echodevo-logo.png" alt="EchoDevo" class="logo-image">
    <div class="actions">
      <a href="/static/coach.html" class="btn btn-sm">
        ← Dashboard
      </a>
      <a href="/static/athlete-calculators.html" class="btn btn-sm btn-primary" id="toolkitBtn">
        Toolkit
      </a>
    </div>
  </div>

  <div class="container mt-4">
    <!-- Profile Header -->
    <div class="profile-header">
      <h2 id="athleteName">Loading...</h2>
      <div class="meta">
        Athlete ID: <span id="athleteId">--</span>
      </div>
    </div>

    <!-- Athlete Quick Info -->
    <div class="athlete-info-card">
      <div class="athlete-info-grid">
        <div class="info-item">
          <div class="info-label">Email</div>
          <div class="info-value">
            <span id="athleteEmail">--</span>
            <a href="#" id="emailLink" class="mail-link" title="Send Email">✉</a>
          </div>
        </div>
        <div class="info-item">
          <div class="info-label">Weight</div>
          <div class="info-value"><span id="athleteWeight">--</span> kg</div>
        </div>
        <div class="info-item">
          <div class="info-label">Height</div>
          <div class="info-value"><span id="athleteHeight">--</span> cm</div>
        </div>
        <div class="info-item">
          <div class="info-label">Sport</div>
          <div class="info-value"><span id="athleteSport">--</span></div>
        </div>
      </div>
      <button class="btn btn-sm btn-primary" onclick="openAthleteInfoModal()">Edit Info</button>
    </div>

    <!-- Race Schedule (Collapsible) -->
    <div class="mb-3">
      <div class="collapsible-header" onclick="toggleRaces()">
        <h3>Race Schedule</h3>
        <span class="collapsible-toggle" id="racesToggle">▼</span>
      </div>
      <div class="collapsible-content" id="racesContent">
        <div style="padding: 16px;">
          <div id="racesContainer">
            <div class="text-center text-muted" style="padding: 32px;">
              Loading races...
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sport Tabs -->
    <div class="tabs">
      <button class="tab active" id="swim-tab" onclick="switchTab('swim')" type="button" data-sport="swim">
        <i class="fas fa-swimmer me-2"></i>SWIM
      </button>
      <button class="tab" id="bike-tab" onclick="switchTab('bike')" type="button" data-sport="bike">
        <i class="fas fa-biking me-2"></i>BIKE
      </button>
      <button class="tab" id="run-tab" onclick="switchTab('run')" type="button" data-sport="run">
        <i class="fas fa-running me-2"></i>RUN
      </button>
    </div>

    <!-- Tab Content -->
    <div class="tab-content" id="sportTabContent">
      
      <!-- SWIM TAB -->
      <div class="tab-pane fade show active" id="swim" role="tabpanel">
        
        <!-- CSS Metric -->
        <div class="metric-card">
          <div class="metric-label">Critical Swim Speed (CSS)</div>
          <div class="metric-value" id="cssValue">--:--</div>
          <div class="metric-source" id="cssSource">per 100m • Not set</div>
        </div>

        <!-- CSS Input Form -->
        <div class="data-table-container mb-3">
          <div class="data-table-header">
            <h3>Edit CSS</h3>
          </div>
          <div style="padding: 16px;">
            <div class="form-group" style="max-width: 300px;">
              <label class="form-label">CSS Pace (MM:SS per 100m)</label>
              <input type="text" class="form-control" id="cssInput" placeholder="e.g., 1:30">
              <div class="form-hint">Format: M:SS (e.g., 1:30 for 90 seconds)</div>
            </div>
            <button class="btn btn-primary" onclick="saveCSS()">Save CSS</button>
            <button class="btn" onclick="openToolkit('swim')">Open Toolkit</button>
          </div>
        </div>

        <!-- Swim Pace Zones -->
        <div class="data-table-container">
          <div class="data-table-header">
            <h3>Swim Pace Zones</h3>
            <p>Pace zones calculated from CSS</p>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th style="width: 60px;">Zone</th>
                <th>Name</th>
                <th>Low</th>
                <th>High</th>
                <th style="width: 100px;">% CSS</th>
              </tr>
            </thead>
            <tbody id="swimZonesBody">
              <tr>
                <td colspan="5" class="text-center text-muted" style="padding: 32px;">
                  No zones defined. Use Toolkit to calculate.
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Swim Interval Pacing -->
        <div class="data-table-container">
          <div class="data-table-header">
            <h3>Swim Interval Pacing</h3>
            <p>Pace targets for various distances and zones</p>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Distance</th>
                <th>Recovery (90-95%)</th>
                <th>Zone 1 (95-97%)</th>
                <th>Zone 2 (97-99%)</th>
                <th>CSS (100%)</th>
              </tr>
            </thead>
            <tbody id="swimIntervalsBody">
              <tr>
                <td colspan="5" class="text-center text-muted" style="padding: 32px;">
                  No intervals defined. Use Toolkit to calculate.
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Swim Tools -->
        <div class="card bg-light">
          <div class="card-body">
            <div class="row g-2">
              <div class="col-md-6">
                <a href="#" onclick="openToolkit('swim'); return false;" class="btn btn-warning w-100">
                  <i class="fas fa-calculator me-2"></i>Open Swim Toolkit
                </a>
                <small class="text-muted d-block mt-1">Calculate CSS, pace zones, swim intervals</small>
              </div>
              <div class="col-md-6">
                <a href="#" id="swimPlannerBtnTab" class="btn btn-primary w-100">
                  <i class="fas fa-swimmer me-2"></i>Swim Planner
                </a>
                <small class="text-muted d-block mt-1">Plan workouts based on your CSS</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- BIKE TAB -->
      <div class="tab-pane fade" id="bike" role="tabpanel">
        
        <!-- Bike Metrics Display - Flat Design -->
        <div class="flat-metric-card">
          <div class="metric-label">Critical Power (CP)</div>
          <div class="metric-value" id="ftpValue">---</div>
          <div class="metric-source" id="ftpSource">Not set</div>
        </div>

        <!-- Edit CP Form - Flat Professional -->
        <div class="border-box">
          <div class="section-header">
            <h4>Edit Critical Power</h4>
          </div>
          <div style="display: grid; grid-template-columns: 1fr auto; gap: var(--space-3); align-items: end;">
            <div>
              <label class="form-label">CP (Watts)</label>
              <input type="number" class="form-control" id="ftpInput" placeholder="e.g., 250">
            </div>
            <button class="btn btn-primary" onclick="saveFTP()" style="height: 38px;">Save CP</button>
          </div>
          <div class="info-note">
            Use the <a href="#" onclick="openToolkit('bike'); return false;">Toolkit</a> to calculate CP, W', and power zones from your power curve.
          </div>
        </div>

        <!-- Bike Power Zones Table -->
        <div class="border-box">
          <div class="section-header" style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <h4>Power Zones</h4>
              <p>Power zones calculated from your CP. Use Toolkit to generate zones.</p>
            </div>
            <button class="btn btn-secondary btn-sm" onclick="syncZonesToTrainingPeaks()" id="syncZonesBtn">
              Sync to TrainingPeaks
            </button>
          </div>
          <div id="zones-sync-status" class="alert alert-info" style="display:none; margin-bottom: var(--space-3);">
            <span id="zones-sync-message"></span>
          </div>
          <table class="modern-table">
            <thead>
              <tr>
                <th style="width: 80px;">Zone</th>
                <th>Name</th>
                <th>Low (W)</th>
                <th>High (W)</th>
                <th style="width: 120px;">% of CP</th>
              </tr>
            </thead>
            <tbody id="bikeZonesBody">
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
