      // Generate weeks
      for (let i = 0; i < MAX_WEEKS_AHEAD; i++) {
        const weekStart = new Date(thisWeekSunday);
        weekStart.setDate(thisWeekSunday.getDate() + (i * 7));
        availableWeeks.push(weekStart);
        
        // Initialize week plan for this week
        const weekKey = formatDateKey(weekStart);
        if (!weekPlan[weekKey]) {
          weekPlan[weekKey] = { days: {} };
          const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
          days.forEach(day => {
            weekPlan[weekKey].days[day] = { workout: null, yardage: null };
          });
        }
      }
      
      // Populate week selector
      populateWeekSelector();
      
      // Start at next week (index 1)
      currentViewWeekIndex = 1;
      renderWeekView();
