          } else {
            yardageSelect.disabled = true;
            yardageSelect.innerHTML = '<option value="">No options</option>';
          }
        } else {
          yardageSelect.disabled = true;
          yardageSelect.innerHTML = '<option value="">-- Select Yardage --</option>';
        }
      } else if (field === 'yardage') {
        weekPlan[weekKey].days[day].yardage = value ? parseInt(value) : null;
      }
      
      // Re-render to update badge counts
      renderWeekView();
    }
    
    function updateScheduleSummary() {
      const cssKey = document.getElementById('libraryCSS').textContent;
      const library = workoutLibrary[cssKey] || [];
      
      let totalWorkouts = 0;
      let weeksWithWorkouts = new Set();
      let summaryHTML = '';
      
      Object.keys(weekPlan).forEach(weekKey => {
        const weekData = weekPlan[weekKey];
        const weekWorkouts = [];
        
        Object.entries(weekData.days).forEach(([day, plan]) => {
          if (plan.workout && plan.yardage) {
            totalWorkouts++;
            weeksWithWorkouts.add(weekKey);
            
            const workout = library.find(w => w.number === plan.workout);
            if (workout) {
              weekWorkouts.push({
                day: day,
                title: workout.title,
                number: workout.number,
                yardage: plan.yardage
              });
            }
          }
        });
        
        if (weekWorkouts.length > 0) {
          const weekDate = new Date(weekKey);
          const weekEnd = new Date(weekDate);
          weekEnd.setDate(weekDate.getDate() + 6);
          
          summaryHTML += `<div class="mb-2"><strong>${formatDate(weekDate)} - ${formatDate(weekEnd)}:</strong><br>`;
          weekWorkouts.forEach(w => {
            summaryHTML += `<small class="text-muted ms-3">• ${w.day.charAt(0).toUpperCase() + w.day.slice(1)}: #${w.number} - ${w.title} (${w.yardage.toLocaleString()} yds)</small><br>`;
          });
          summaryHTML += '</div>';
        }
      });
      
      if (totalWorkouts === 0) {
        summaryHTML = '<em class="text-muted">No workouts scheduled yet</em>';
      }
      
      document.getElementById('scheduleSummary').innerHTML = summaryHTML;
      document.getElementById('totalWorkoutsCount').textContent = totalWorkouts;
      document.getElementById('totalWeeksCount').textContent = weeksWithWorkouts.size;
    }
    
    function clearWeekPlan() {
      if (!confirm('Clear all scheduled workouts?')) return;
      
      // Reset all week plans
      Object.keys(weekPlan).forEach(weekKey => {
        const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
        days.forEach(day => {
          weekPlan[weekKey].days[day] = { workout: null, yardage: null };
        });
      });
      
      renderWeekView();
      console.log('All week plans cleared');
    }

    async function pushToTrainingPeaks() {
      if (!athleteId) {
        alert('No athlete selected');
        return;
      }

      // Count total selected workouts across all weeks
      let totalSelected = 0;
      Object.keys(weekPlan).forEach(weekKey => {
        Object.values(weekPlan[weekKey].days).forEach(day => {
          if (day.workout && day.yardage) totalSelected++;
        });
      });

      if (totalSelected === 0) {
        alert('Please select at least one workout with yardage before pushing to TrainingPeaks.');
        return;
      }

      const pushButton = document.getElementById('pushButton');
      pushButton.disabled = true;
      pushButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Pushing...';

      try {
        // Get CSS key and library
        const cssKey = document.getElementById('libraryCSS').textContent;
        const library = workoutLibrary[cssKey] || [];

        // Build workout list for all weeks
        const workoutsToCreate = [];
        const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
        
        Object.keys(weekPlan).forEach(weekKey => {
          const weekStart = new Date(weekKey);
          
          days.forEach((day, dayOffset) => {
            const plan = weekPlan[weekKey].days[day];
            if (plan.workout && plan.yardage) {
              const workout = library.find(w => w.number === plan.workout);
              if (workout) {
                const workoutDate = new Date(weekStart);
                workoutDate.setDate(weekStart.getDate() + dayOffset);
                
                // Strip markdown from description
                let description = workout.descriptions[plan.yardage] || '';
                description = description
                  .replace(/\*\*([^*]+)\*\*/g, '$1')  // Remove bold
                  .replace(/\*([^*]+)\*/g, '$1')      // Remove italic
                  .replace(/#{1,6}\s+/g, '')          // Remove headers
                  .trim();
                
                workoutsToCreate.push({
                  date: workoutDate.toISOString().split('T')[0],
                  title: `${workout.title} [WKT #${workout.number}]`,
                  description: description,
                  distance: Math.round(plan.yardage * 0.9144), // Convert yards to meters
                  tss: workout.estimated_tss[plan.yardage],
                  duration: workout.estimated_duration[plan.yardage]
                });
              }
            }
          });
        });

        console.log('🚀 Pushing workouts to TrainingPeaks:', workoutsToCreate);

        // Call API to push workouts
        const response = await axios.post('/api/swim/push-workouts', {
          athlete_id: athleteId,
          workouts: workoutsToCreate
        });

        console.log('📥 Push API Response:', response.data);

        if (response.data.success) {
          alert(`✅ Success! Pushed ${workoutsToCreate.length} workout(s) to TrainingPeaks.\n\n${response.data.message || ''}`);
          
          // Clear the plan after successful push
          clearWeekPlan();
          
          // Reload workouts to show the new ones
          loadSwimWorkouts();
        } else {
          // Show detailed error information
          console.error('❌ Push failed:', response.data);
          let errorMsg = `Failed to push workouts:\n\n`;
          errorMsg += `Success: ${response.data.summary.success}/${response.data.summary.total}\n`;
          if (response.data.errors && response.data.errors.length > 0) {
            errorMsg += `\nErrors:\n`;
            response.data.errors.forEach(err => {
              errorMsg += `- ${err.date} ${err.title}: ${err.error}\n`;
            });
          }
          throw new Error(errorMsg);
        }
      } catch (error) {
        console.error('Error pushing to TrainingPeaks:', error);
        alert(`❌ Error: ${error.response?.data?.error || error.message || 'Failed to push workouts'}`);
      } finally {
        pushButton.disabled = false;
        pushButton.innerHTML = '<i class="fas fa-cloud-upload-alt me-2"></i>Push to TrainingPeaks';
      }
    }

    // Load athlete and workouts on page load
    async function initPage() {
      await loadAthleteInfo();
      
      // Initialize week planner with CSS
      const cssSeconds = document.getElementById('cssSeconds').textContent;
      let cssKey = '1:40'; // Default
      
      // Parse CSS from display (e.g., "(100 seconds per 100m)")
      const match = cssSeconds.match(/(\d+) seconds/);
      if (match) {
        const seconds = parseInt(match[1]);
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        cssKey = `${mins}:${secs.toString().padStart(2, '0')}`;
      }
      
      initWeekPlanner(cssKey);
      loadSwimWorkouts();
    }

    initPage();
  </script>
