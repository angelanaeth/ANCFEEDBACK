    function populateWeekSelector() {
      const selector = document.getElementById('weekSelector');
      selector.innerHTML = '';
      
      availableWeeks.forEach((weekStart, index) => {
        const weekEnd = new Date(weekStart);
        weekEnd.setDate(weekStart.getDate() + 6);
        
        let label = '';
        const today = new Date();
        const currentWeekIndex = availableWeeks.findIndex(w => {
          const thisDay = today.getDay();
          const thisWeekSunday = new Date(today);
          thisWeekSunday.setDate(today.getDate() - thisDay);
          return formatDateKey(w) === formatDateKey(thisWeekSunday);
        });
        
        if (index === currentWeekIndex) {
          label = `This Week (${formatDate(weekStart)} - ${formatDate(weekEnd)})`;
        } else if (index === currentWeekIndex + 1) {
          label = `Next Week (${formatDate(weekStart)} - ${formatDate(weekEnd)})`;
        } else if (index < currentWeekIndex) {
          const weeksAgo = currentWeekIndex - index;
          label = `${weeksAgo} week${weeksAgo > 1 ? 's' : ''} ago (${formatDate(weekStart)} - ${formatDate(weekEnd)})`;
        } else {
          const weeksAhead = index - currentWeekIndex;
          label = `In ${weeksAhead} week${weeksAhead > 1 ? 's' : ''} (${formatDate(weekStart)} - ${formatDate(weekEnd)})`;
        }
        
        const option = document.createElement('option');
        option.value = index;
        option.textContent = label;
        selector.appendChild(option);
      });
      
      selector.value = currentViewWeekIndex;
