  /* ====================================================
     BEST EFFORT PACE — RUN
     ==================================================== */
  function calcBEP2() {
    var csMin = intVal('bep2-cs-min',0), csSec = intVal('bep2-cs-sec',0);
    var csSecPerMile = (csMin * 60) + csSec;
    var dPrime = num('bep2-dprime');
    var volEl  = el('bep2-volume');
    var volume = volEl ? parseFloat(volEl.value) : 0.70;
    if (!isFinitePositive(csSecPerMile) || !isFinitePositive(dPrime)) return showError('bep2-results','Enter CS + D\'.');

    var csMps = paceSecondsPerMileToMetersPerSecond(csSecPerMile);

    var distances    = [200,400,600,800,1000,1200,1500,1600,3200];
    var intervalRows = distances.map(function(d) {
      var t    = (d - dPrime) / csMps;
      var pace = (t / d) * METERS_PER_MILE;
      return [d + 'm', secondsToClock(t), secondsToPace(pace,'/mi'), secondsToClock(t*1.03) + '–' + secondsToClock(t*(1.08+(1-volume)*0.03))];
    });

    var races    = [['5K',5000,1.00,1.05],['10K',10000,0.95,0.98],['Half Marathon',21097,0.90,0.95],['Marathon',42195,0.85,0.90]];
    var raceRows = races.map(function(r) {
      var t    = (r[1] - dPrime) / csMps;
      var pace = (t / r[1]) * METERS_PER_MILE;
      return [r[0], secondsToClock(t), secondsToPace(pace,'/mi'),
        secondsToPace(paceForPercentOfSpeed(csSecPerMile,r[3]),'/mi') + '–' + secondsToPace(paceForPercentOfSpeed(csSecPerMile,r[2]),'/mi')];
    });

    var tri    = [['Sprint',0.95,0.98],['Olympic',0.90,0.94],['70.3',0.85,0.90],['Ironman',0.80,0.85]];
    var triRows= tri.map(function(t) {
      return [t[0], secondsToPace(paceForPercentOfSpeed(csSecPerMile,t[2]),'/mi') + '–' + secondsToPace(paceForPercentOfSpeed(csSecPerMile,t[1]),'/mi')];
    });

    var percents = [1.02,1.05,1.08,1.10,1.20,1.50,2.00];
    var maxRows  = percents.map(function(p) {
      var pace  = paceForPercentOfSpeed(csSecPerMile, p);
      var speed = paceSecondsPerMileToMetersPerSecond(pace);
      var t     = dPrime / (speed - csMps);
      return [Math.round(p*100) + '%', secondsToPace(pace,'/mi'), t > 0 ? secondsToClock(t) : '—'];
    });

    // Store results for saving
    calculatedResults.bep = {
      intervals: intervalRows,
      races: raceRows,
      triathlon: triRows,
      maximal: maxRows
    };

    renderResult('bep2-results',
      renderResultBox('Intervals',          renderSimpleTable(['Distance','Time','Pace','Range'],     intervalRows)) +
      '<div style="height:12px;"></div>' +
      renderResultBox('Race Predictions',   renderSimpleTable(['Race','Time','Pace','Target'],        raceRows))    +
      '<div style="height:12px;"></div>' +
      renderResultBox('Triathlon Run Pacing',renderSimpleTable(['Race','Target Pace'],                triRows))     +
      '<div style="height:12px;"></div>' +
      renderResultBox('Maximal Time Pace Can Be Maintained', renderSimpleTable(['%CS','Pace','Time'], maxRows)) +
      '<div style="height:12px;"></div>' +
      '<button onclick="saveBEPToProfile()" class="qt2-calc-btn" style="background: #16a34a;">\u{1F4BE} Save to Profile</button>'
    );
  }

