  function calcCP2() {
    var t1 = parseMinSecPair('cp2-short-min','cp2-short-sec');
    var t2 = parseMinSecPair('cp2-long-min', 'cp2-long-sec');
    var w1 = num('cp2-short-w');
    var w2 = num('cp2-long-w');
    if (![t1,t2,w1,w2].every(isFinitePositive) || t1 === t2) return showError('cp2-results', 'Enter valid CP inputs.');
    var cp     = ((w1 * t1) - (w2 * t2)) / (t1 - t2);
    var wPrime = (w1 - cp) * t1;
    renderCP('cp2-results', cp, wPrime);
  }
  function calcCP3() {
    var t = [
      parseMinSecPair('cp3-short-min','cp3-short-sec'),
      parseMinSecPair('cp3-med-min',  'cp3-med-sec'),
      parseMinSecPair('cp3-long-min', 'cp3-long-sec')
    ];
    var w = [num('cp3-short-w'), num('cp3-med-w'), num('cp3-long-w')];
    if (![].concat(t,w).every(isFinitePositive)) return showError('cp3-results', 'Enter all CP inputs.');
    var work = t.map(function(x,i) { return x * w[i]; });
    var fit  = leastSquaresSlopeIntercept(t, work);
    if (!fit) return showError('cp3-results', 'Calculation failed.');
    renderCP('cp3-results', fit.slope, fit.intercept);
  }

  /* ====================================================
     BEST EFFORT WATTAGE
     ==================================================== */
  function calcBEW() {
    var cp     = num('bew-cp');
    var wPrime = num('bew-wprime');
    if (!isFinitePositive(cp) || !isFinitePositive(wPrime)) return showError('bew-results', 'Enter CP + W\'.');

    var durations    = [60,120,150,180,240,300,360,480,600,720,900,1200];
    var intervalRows = durations.map(function(sec) {
      var peak = cp + (wPrime / sec);
      return [sec/60 + ' min', Math.round(peak) + ' W', Math.round(peak*0.90) + '–' + Math.round(peak*0.96) + ' W'];
    });

    var percents  = [1.02,1.05,1.08,1.10,1.20,1.50,2.00];
    var sustainRows = percents.map(function(p) {
      var watts = cp * p;
      var time  = wPrime / (watts - cp);
      return [Math.round(p*100) + '%', Math.round(watts) + ' W', time > 0 ? secondsToClock(time) : '—'];
    });

    /* Optional custom interval */
    var custMin = intVal('bew-custom-min',0), custSec = intVal('bew-custom-sec',0);
    var custTot = custMin * 60 + custSec;
    var customHTML = '';
    if (custTot > 0) {
      var custPeak = cp + (wPrime / custTot);
      customHTML = '<div style="height:12px;"></div>' +
        renderResultBox('Custom Interval (' + custMin + ':' + pad(custSec) + ')',
          '<div class="qt2-result-grid">' +
          makeStat('Peak Power',   Math.round(custPeak),                              'W') +
          makeStat('Target Range', Math.round(custPeak*0.90) + '–' + Math.round(custPeak*0.96), 'W') +
          '</div>');
    }

    // Store results for saving
    calculatedResults.bew = {
      cp: cp,
      wPrime: wPrime,
      intervals: intervalRows,
      sustainLevels: sustainRows
    };

    renderResult('bew-results',
      renderResultBox('Best Effort Wattage Targets', renderSimpleTable(['Duration','Peak Power','Recommended Range'], intervalRows)) +
      '<div style="height:12px;"></div>' +
      renderResultBox('Maximal Time Wattage Can Be Maintained', renderSimpleTable(['% of CP','Wattage','Time'], sustainRows)) +
      customHTML +
      '<div style="height:12px;"></div>' +
      '<button onclick="saveBEWToProfile()" class="qt2-calc-btn" style="background: #16a34a;">\u{1F4BE} Save to Profile</button>'
    );
  }

