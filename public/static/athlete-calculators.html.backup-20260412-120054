  /* ====================================================
     EXPANDED POWER ZONES CALCULATOR
     ==================================================== */
  // Zone definitions matching the bikecalculator.docx
  const ZONE_DEFS = [
    { name: 'Recovery', sweet: false, div: [0, 0.50] },
    { name: 'Endurance', sweet: false, div: [0.50, 'lt1'] },
    { name: 'Tempo', sweet: false, div: ['lt1', 'ogc'] },
    { name: 'Sweet Spot', sweet: true, div: ['ogc', 'cp'] },
    { name: 'Threshold', sweet: false, div: ['cp', 1.05] },
    { name: 'VO2 Max', sweet: false, div: [1.05, 1.20] }
  ];

  function calcPowerZones(CP, LT1, OGC) {
    const zones = [];
    for (let z of ZONE_DEFS) {
      let lo = z.div[0];
      let hi = z.div[1];
      
      // Resolve special markers
      if (lo === 'lt1') lo = LT1 / CP;
      if (lo === 'ogc') lo = OGC / CP;
      if (hi === 'lt1') hi = LT1 / CP;
      if (hi === 'ogc') hi = OGC / CP;
      if (hi === 'cp') hi = 1.0;
      
      // Calculate wattages
      const lowW = Math.round(CP * lo);
      const highW = Math.round(CP * hi);
      
      zones.push({
        name: z.name,
        sweet: z.sweet,
        low: lowW,
        high: highW
      });
    }
    return zones;
  }

  function renderPowerZones() {
    const CP = parseFloat(document.getElementById('pz-cp').value) || 0;
    const LT1 = parseFloat(document.getElementById('pz-lt1').value) || 0;
    const OGC = parseFloat(document.getElementById('pz-ogc').value) || 0;
    
    const tbody = document.getElementById('pz-zones-tbody');
    
    if (!CP || !LT1 || !OGC) {
      tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;color:var(--qt2-muted);padding:20px;">Enter all threshold values above to generate zones...</td></tr>';
      return;
    }
    
    const zones = calcPowerZones(CP, LT1, OGC);
    let html = '';
    
    for (let z of zones) {
      const sweetBadge = z.sweet 
        ? '<span style="display:inline-block;margin-left:8px;padding:2px 8px;background:#16a34a;color:#fff;border-radius:4px;font-size:11px;font-weight:600;letter-spacing:0.02em;">SWEET SPOT</span>' 
        : '';
      
      html += `<tr>
        <td>${z.name}${sweetBadge}</td>
        <td class="num-cell">${z.low} W</td>
        <td class="num-cell">${z.high} W</td>
      </tr>`;
    }
    
    tbody.innerHTML = html;
  }

