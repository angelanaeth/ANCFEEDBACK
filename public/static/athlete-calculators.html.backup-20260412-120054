  /* ====================================================
     SWIM INTERVAL PACING
     ==================================================== */
  function calcSIP() {
    var css = parseMinSecPair('sip-cs-min','sip-cs-sec');
    if (!isFinitePositive(css)) return showError('sip-results','Enter CSS pace.');
    var zones = { zr: css+8, z1: css+5, z2: css+2, cs: css, fast: css-3, faster: css-6 };
    var distances = [25,50,75,100,125,150,200,300,400,500,600,800,1000];
    var custom = num('sip-custom', 0);
