    var rows = distances.map(function(d) {
      return [d + '',
        secondsToClock((zones.zr/100)*d),
        secondsToClock((zones.z1/100)*d),
        secondsToClock((zones.z2/100)*d),
        secondsToClock((zones.cs/100)*d),
        secondsToClock((zones.fast/100)*d),
        secondsToClock((zones.faster/100)*d)
      ];
    });
    renderResult('sip-results', renderResultBox('Swim Interval Table', renderSimpleTable(['Dist','ZR','Z1','Z2','CS','Fast','Faster'], rows)));
