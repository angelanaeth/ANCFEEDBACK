  /* ====================================================
     CRITICAL SPEED — RUN
     ==================================================== */
  function runCSFromTrials(distances, times) {
    var fit = leastSquaresSlopeIntercept(times, distances);
    if (!fit || fit.slope <= 0) return null;
    return { csMps: fit.slope, dPrime: fit.intercept };
  }

  function renderRunCS(containerId, csMps, dPrime) {
    // Store values globally for saving
    calculatedResults.runCS = csMps;
    calculatedResults.runDPrime = dPrime;
    
    var secPerMile = metersPerSecondToSecondsPerMile(csMps);
    var vo2Mps     = csMps + (dPrime / 600);
    var vo2Pace    = metersPerSecondToSecondsPerMile(vo2Mps);
    var ratio      = csMps / vo2Mps;
    var phys       = 'Balanced';
    if (ratio < 0.85) phys = 'Anaerobic';
    else if (ratio > 0.88) phys = 'Aerobic';

    function fmt(lo, hi) { return secondsToPace(lo,'/mi') + ' – ' + secondsToPace(hi,'/mi'); }

    var zoneRows = [
      ['Z1',       fmt(secPerMile/0.85, secPerMile/0.75)],
      ['Z2',       fmt(secPerMile/0.95, secPerMile/0.85)],
      ['Z3 (CS)',  fmt(secPerMile/1.00, secPerMile/0.95)],
      ['Z4 (VO2)', fmt(secPerMile/1.10, secPerMile/1.00)]
    ];
    var fiberRows = [
      ['Very Easy',           '> ' + secondsToPace(secPerMile/0.56,'/mi')],
      ['Type I',              secondsToPace(secPerMile/0.75,'/mi') + ' – ' + secondsToPace(secPerMile/0.56,'/mi')],
      ['Type IIA Oxidative',  secondsToPace(secPerMile/0.90,'/mi') + ' – ' + secondsToPace(secPerMile/0.75,'/mi')],
      ['Type IIA Glycolytic', secondsToPace(secPerMile/1.05,'/mi') + ' – ' + secondsToPace(secPerMile/0.90,'/mi')],
      ['Type IIX',            secondsToPace(secPerMile/1.50,'/mi') + ' – ' + secondsToPace(secPerMile/1.05,'/mi')]
    ];

    var statGrid = '<div class="qt2-result-grid">' +
      makeStat('CS Pace',     secondsToPace(secPerMile,'/mi')) +
      makeStat("D'",          dPrime.toFixed(0), 'm')          +
      makeStat('VO2 Max Pace',secondsToPace(vo2Pace,'/mi'))    +
      makeStat('CS:VO2 Max',  (ratio*100).toFixed(1), '%')     +
      makeStat('Physiology',  phys)                            +
    '</div>';
    
    var saveBtn = athleteId ? '<button class="qt2-calc-btn" onclick="saveRunCSToProfile()" style="margin-top:12px;background:#16a34a;">💾 Save to Profile</button>' : '';
    var tpSyncBtn = athleteId ? '<button class="qt2-calc-btn" onclick="syncRunZonesToTrainingPeaks()" style="margin-top:12px;margin-left:8px;background:#2563eb;">🔄 Sync to TrainingPeaks</button>' : '';

    renderResult(containerId,
