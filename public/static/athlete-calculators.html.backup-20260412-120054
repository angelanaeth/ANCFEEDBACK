<script>
// ===== ATHLETE CONTEXT INTEGRATION =====
const urlParams = new URLSearchParams(window.location.search);
const athleteId = urlParams.get('athlete');
let currentAthlete = null;

// Load athlete data if ID is present
if (athleteId) {
  axios.get(`/api/athlete-profile/${athleteId}`)
    .then(response => {
      currentAthlete = response.data;
      const athleteInfoDiv = document.getElementById('athlete-info');
      if (athleteInfoDiv && currentAthlete) {
        athleteInfoDiv.textContent = `Athlete: ${currentAthlete.first_name || ''} ${currentAthlete.last_name || ''}`;
      }
    })
    .catch(error => {
      console.error('Error loading athlete data:', error);
    });
}

// Global storage for calculator results
let calculatedResults = {
  cp: null,
  wPrime: null,
  runCS: null,
  runDPrime: null,
  swimCSS: null,
  vo2Bike: null,
  vo2Run: null
};

// API Save Functions
async function saveToDatabase(endpoint, data) {
  if (!athleteId) {
    alert('No athlete ID provided. Cannot save.');
    return false;
  }
  try {
    const response = await axios.put(endpoint, { ...data });
    alert('✅ Saved successfully!');
    return true;
  } catch (error) {
    console.error('Save error:', error);
    alert('❌ Error saving: ' + (error.response?.data?.error || error.message));
    return false;
  }
}

// Save Critical Power to athlete profile
async function saveCPToProfile() {
  if (!calculatedResults.cp || !calculatedResults.wPrime) {
    alert('Please calculate CP first.');
    return;
  }
  
  const cp = calculatedResults.cp;
  const zones = {
    recovery: {
      min_watts: 0,
      max_watts: Math.round(cp * 0.65),
      name: 'Recovery'
    },
    endurance: {
      min_watts: Math.round(cp * 0.65),
      max_watts: Math.round(cp * 0.79),
      name: 'Endurance'
    },
    tempo: {
      min_watts: Math.round(cp * 0.79),
      max_watts: Math.round(cp * 0.89),
      name: 'Tempo'
    },
    threshold: {
      min_watts: Math.round(cp * 0.89),
      max_watts: Math.round(cp * 1.00),
      name: 'Threshold'
    }
  };
  
  await saveToDatabase(`/api/athlete-profile/${athleteId}`, {
    bike_ftp: Math.round(cp),
    bike_ftp_source: 'toolkit',
    bike_ftp_updated_at: new Date().toISOString(),
    bike_power_zones: JSON.stringify(zones),
    bike_wprime: Math.round(calculatedResults.wPrime)
  });
}

// Save Run Critical Speed to athlete profile
async function saveRunCSToProfile() {
  if (!calculatedResults.runCS || !calculatedResults.runDPrime) {
    alert('Please calculate Critical Speed first.');
    return;
  }
  
  const cs = calculatedResults.runCS; // m/s
  const pacePerMile = 1609.344 / cs; // seconds per mile
  
  await saveToDatabase(`/api/athlete-profile/${athleteId}`, {
    run_threshold_pace: pacePerMile,
    run_threshold_source: 'toolkit',
    run_threshold_updated_at: new Date().toISOString(),
    run_dprime: Math.round(calculatedResults.runDPrime)
  });
}

// Save Swim Critical Speed to athlete profile
async function saveSwimCSSToProfile() {
  if (!calculatedResults.swimCSS) {
    alert('Please calculate CSS first.');
    return;
  }
  
  const css = calculatedResults.swimCSS; // m/s
  const pacePer100 = 100 / css; // seconds per 100m
  
  await saveToDatabase(`/api/athlete-profile/${athleteId}`, {
    swim_threshold_pace: pacePer100,
    swim_threshold_source: 'toolkit',
    swim_threshold_updated_at: new Date().toISOString()
  });
}

// Sync zones to TrainingPeaks (Bike Power)
async function syncZonesToTrainingPeaks() {
  if (!calculatedResults.cp || !athleteId) {
    alert('Please calculate CP first and ensure athlete is selected.');
    return;
  }
  
  const cp = calculatedResults.cp;
  const zones = [
    { min: 0, max: Math.round(cp * 0.65) },
    { min: Math.round(cp * 0.65), max: Math.round(cp * 0.79) },
    { min: Math.round(cp * 0.79), max: Math.round(cp * 0.89) },
    { min: Math.round(cp * 0.89), max: Math.round(cp * 1.00) }
  ];
  
  try {
    const response = await axios.post(`/api/trainingpeaks/zones/${athleteId}`, {
      sport: 'bike',
      type: 'power',
      zones: { zones }
    });
    
    if (response.data.success) {
      alert('✅ Zones synced to TrainingPeaks successfully!');
    }
  } catch (error) {
    console.error('TP sync error:', error);
    alert('❌ Error syncing to TrainingPeaks: ' + (error.response?.data?.error || error.message));
  }
}

// Sync run pace zones to TrainingPeaks
async function syncRunZonesToTrainingPeaks() {
  if (!calculatedResults.runCS || !athleteId) {
    alert('Please calculate Critical Speed first and ensure athlete is selected.');
    return;
  }
  
  const cs = calculatedResults.runCS; // m/s
  const pacePerKm = 1000 / cs; // seconds per km
  
  // Calculate pace zones (in seconds per km)
  const zones = [
    { min: Math.round(pacePerKm * 1.15), max: 9999 }, // Recovery (slower than 115% CS)
    { min: Math.round(pacePerKm * 1.08), max: Math.round(pacePerKm * 1.15) }, // Z1 (108-115%)
    { min: Math.round(pacePerKm * 1.02), max: Math.round(pacePerKm * 1.08) }, // Z2 (102-108%)
    { min: Math.round(pacePerKm * 1.00), max: Math.round(pacePerKm * 1.02) }  // Z3 (100-102%)
  ];
  
  try {
    const response = await axios.post(`/api/trainingpeaks/zones/${athleteId}`, {
      sport: 'run',
      type: 'pace',
      zones: { zones }
    });
    
    if (response.data.success) {
      alert('✅ Run pace zones synced to TrainingPeaks successfully!');
    }
  } catch (error) {
    console.error('TP sync error:', error);
    alert('❌ Error syncing to TrainingPeaks: ' + (error.response?.data?.error || error.message));
  }
}

