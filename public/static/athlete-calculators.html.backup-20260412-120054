<!-- ===================== CRITICAL POWER ===================== -->
<div class="qt2-panel" id="tab-critical-power">
  <h2 class="qt2-calc-title">Critical Power (Bike / Run)</h2>
  <p class="qt2-instructions">For a three-point test use the 3-Point calculator (2–3 min, 4–6 min, 12–15 min). For a two-point test use the 2-Point calculator. Fill in the blue cells with times and average wattage. Outputs appear in gray.</p>
  <div class="qt2-two-col">
    <!-- 3-Point -->
    <div class="qt2-card">
      <h3>Three-Point Critical Power (Bike)</h3>
      <div class="qt2-field-group">
        <label>Short Test Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="cp3-short-min" value="3" min="0"> <span>min</span>
          <input type="number" class="qt2-input" id="cp3-short-sec" value="0" min="0" max="59"> <span>sec</span>
        </div>
        <label>Short Test Avg Wattage</label>
        <input type="number" class="qt2-input" id="cp3-short-w" value="242"> <span class="qt2-unit">watts</span>
      </div>
      <div class="qt2-field-group">
        <label>Medium Test Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="cp3-med-min" value="6" min="0"> <span>min</span>
          <input type="number" class="qt2-input" id="cp3-med-sec" value="0" min="0" max="59"> <span>sec</span>
        </div>
        <label>Medium Test Avg Wattage</label>
        <input type="number" class="qt2-input" id="cp3-med-w" value="210"> <span class="qt2-unit">watts</span>
      </div>
      <div class="qt2-field-group">
        <label>Long Test Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="cp3-long-min" value="12" min="0"> <span>min</span>
          <input type="number" class="qt2-input" id="cp3-long-sec" value="0" min="0" max="59"> <span>sec</span>
        </div>
        <label>Long Test Avg Wattage</label>
        <input type="number" class="qt2-input" id="cp3-long-w" value="198"> <span class="qt2-unit">watts</span>
      </div>
      <button class="qt2-calc-btn" data-calc="cp3">Calculate</button>
      <div class="qt2-results" id="cp3-results"></div>
    </div>
    <!-- 2-Point -->
    <div class="qt2-card">
      <h3>Two-Point Critical Power (Bike)</h3>
      <div class="qt2-field-group">
        <label>Short Test Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="cp2-short-min" value="3" min="0"> <span>min</span>
          <input type="number" class="qt2-input" id="cp2-short-sec" value="0" min="0" max="59"> <span>sec</span>
        </div>
        <label>Short Test Avg Wattage</label>
        <input type="number" class="qt2-input" id="cp2-short-w" value="315"> <span class="qt2-unit">watts</span>
      </div>
      <div class="qt2-field-group">
        <label>Long Test Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="cp2-long-min" value="12" min="0"> <span>min</span>
          <input type="number" class="qt2-input" id="cp2-long-sec" value="0" min="0" max="59"> <span>sec</span>
        </div>
        <label>Long Test Avg Wattage</label>
        <input type="number" class="qt2-input" id="cp2-long-w" value="290"> <span class="qt2-unit">watts</span>
      </div>
      <button class="qt2-calc-btn" data-calc="cp2">Calculate</button>
      <div class="qt2-results" id="cp2-results"></div>
    </div>
  </div>
</div>

<!-- ===================== BEST EFFORT WATTAGE ===================== -->
<div class="qt2-panel" id="tab-best-effort-watts">
  <h2 class="qt2-calc-title">Best Effort Wattage Intervals (Bike / Run)</h2>
  <p class="qt2-instructions">Enter Critical Power and W' (Anaerobic Capacity) to calculate pre-determined best effort wattage intervals. Optionally enter a custom interval length.</p>
  <div class="qt2-card">
    <div class="qt2-inline-fields">
      <div class="qt2-field-group">
        <label>Critical Power</label>
        <input type="number" class="qt2-input" id="bew-cp" value="352"> <span class="qt2-unit">watts</span>
      </div>
      <div class="qt2-field-group">
        <label>W' (Anaerobic Capacity)</label>
        <input type="number" class="qt2-input" id="bew-wprime" value="19620"> <span class="qt2-unit">joules</span>
      </div>
      <div class="qt2-field-group">
        <label>Custom Interval</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="bew-custom-min" value="30" min="0"> <span>min</span>
          <input type="number" class="qt2-input" id="bew-custom-sec" value="0" min="0" max="59"> <span>sec</span>
        </div>
      </div>
    </div>
    <button class="qt2-calc-btn" data-calc="bew">Calculate</button>
    <div class="qt2-results" id="bew-results"></div>
  </div>
</div>

<!-- ===================== CRITICAL SPEED RUN ===================== -->
<div class="qt2-panel" id="tab-critical-speed-run">
  <h2 class="qt2-calc-title">Critical Speed (Run)</h2>
  <p class="qt2-instructions">Calculate Critical Speed from timed test efforts at two or three distances. Results include pace per mile, training zones, and race predictions.</p>
  <div class="qt2-two-col">
    <!-- 3-Point -->
    <div class="qt2-card">
      <h3>Three-Point Test</h3>
      <div class="qt2-field-group">
        <label>Short Distance</label>
        <input type="number" class="qt2-input" id="csr3-d1" value="400"> <span class="qt2-unit">meters</span>
      </div>
      <div class="qt2-field-group">
        <label>Short Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="csr3-t1-min" value="1"> <span>min</span>
          <input type="number" class="qt2-input" id="csr3-t1-sec" value="19"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Medium Distance</label>
        <input type="number" class="qt2-input" id="csr3-d2" value="800"> <span class="qt2-unit">meters</span>
      </div>
      <div class="qt2-field-group">
        <label>Medium Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="csr3-t2-min" value="2"> <span>min</span>
          <input type="number" class="qt2-input" id="csr3-t2-sec" value="48"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Long Distance</label>
        <input type="number" class="qt2-input" id="csr3-d3" value="3200"> <span class="qt2-unit">meters</span>
      </div>
      <div class="qt2-field-group">
        <label>Long Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="csr3-t3-min" value="12"> <span>min</span>
          <input type="number" class="qt2-input" id="csr3-t3-sec" value="57"> <span>sec</span>
        </div>
      </div>
      <button class="qt2-calc-btn" data-calc="csr3">Calculate</button>
      <div class="qt2-results" id="csr3-results"></div>
    </div>
    <!-- 2-Point -->
    <div class="qt2-card">
      <h3>Two-Point Test</h3>
      <div class="qt2-field-group">
        <label>Short Distance</label>
        <input type="number" class="qt2-input" id="csr2-d1" value="400"> <span class="qt2-unit">meters</span>
      </div>
      <div class="qt2-field-group">
        <label>Short Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="csr2-t1-min" value="1"> <span>min</span>
          <input type="number" class="qt2-input" id="csr2-t1-sec" value="5"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Long Distance</label>
        <input type="number" class="qt2-input" id="csr2-d2" value="800"> <span class="qt2-unit">meters</span>
      </div>
      <div class="qt2-field-group">
        <label>Long Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="csr2-t2-min" value="2"> <span>min</span>
          <input type="number" class="qt2-input" id="csr2-t2-sec" value="37"> <span>sec</span>
        </div>
      </div>
      <button class="qt2-calc-btn" data-calc="csr2">Calculate</button>
      <div class="qt2-results" id="csr2-results"></div>
    </div>
  </div>
</div>

<!-- ===================== BEST EFFORT PACE ===================== -->
<div class="qt2-panel" id="tab-best-effort-pace">
  <h2 class="qt2-calc-title">Best Effort Pace Intervals (Run)</h2>
  <p class="qt2-instructions">Enter athlete's Critical Speed pace, D' value, and typical weekly running volume to generate predicted race times, target paces, and recommended interval targets.</p>
  <div class="qt2-card">
    <div class="qt2-inline-fields">
      <div class="qt2-field-group">
        <label>Critical Speed Pace</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="bep2-cs-min" value="7"> <span>min</span>
          <input type="number" class="qt2-input" id="bep2-cs-sec" value="40"> <span>sec /mi</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>D' (meters)</label>
        <input type="number" class="qt2-input" id="bep2-dprime" value="200">
      </div>
      <div class="qt2-field-group">
        <label>Weekly Running Volume</label>
        <select class="qt2-select" id="bep2-volume">
          <option value="0.60">Under 25 Miles/Week</option>
          <option value="0.70" selected>30–37 Miles/Week</option>
          <option value="0.75">38–45 Miles/Week</option>
          <option value="0.80">46–55 Miles/Week</option>
          <option value="0.85">56–65 Miles/Week</option>
          <option value="0.90">66+ Miles/Week</option>
        </select>
      </div>
    </div>
    <button class="qt2-calc-btn" data-calc="bep2">Calculate</button>
    <div class="qt2-results" id="bep2-results"></div>
  </div>
</div>

<!-- ===================== CRITICAL SPEED SWIM ===================== -->
<div class="qt2-panel" id="tab-critical-speed-swim">
  <h2 class="qt2-calc-title">Critical Speed (Swim)</h2>
  <p class="qt2-instructions">Calculate swim Critical Speed and D' from timed test efforts. Results in pace per 100 yards/meters and training zones.</p>
  <div class="qt2-two-col">
    <!-- 3-Point -->
    <div class="qt2-card">
      <h3>Three-Point Test</h3>
      <div class="qt2-field-group">
        <label>Short Distance</label>
        <input type="number" class="qt2-input" id="css3-d1" value="150"> <span class="qt2-unit">yds/m</span>
      </div>
      <div class="qt2-field-group">
        <label>Short Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="css3-t1-min" value="0"> <span>min</span>
          <input type="number" class="qt2-input" id="css3-t1-sec" value="24"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Medium Distance</label>
        <input type="number" class="qt2-input" id="css3-d2" value="300"> <span class="qt2-unit">yds/m</span>
      </div>
      <div class="qt2-field-group">
        <label>Medium Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="css3-t2-min" value="4"> <span>min</span>
          <input type="number" class="qt2-input" id="css3-t2-sec" value="20"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Long Distance</label>
        <input type="number" class="qt2-input" id="css3-d3" value="600"> <span class="qt2-unit">yds/m</span>
      </div>
      <div class="qt2-field-group">
        <label>Long Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="css3-t3-min" value="8"> <span>min</span>
          <input type="number" class="qt2-input" id="css3-t3-sec" value="50"> <span>sec</span>
        </div>
      </div>
      <button class="qt2-calc-btn" data-calc="css3">Calculate</button>
      <div class="qt2-results" id="css3-results"></div>
    </div>
    <!-- 2-Point -->
    <div class="qt2-card">
      <h3>Two-Point Test</h3>
      <div class="qt2-field-group">
        <label>Short Distance</label>
        <input type="number" class="qt2-input" id="css2-d1" value="150"> <span class="qt2-unit">yds/m</span>
      </div>
      <div class="qt2-field-group">
        <label>Short Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="css2-t1-min" value="2"> <span>min</span>
          <input type="number" class="qt2-input" id="css2-t1-sec" value="33"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Long Distance</label>
        <input type="number" class="qt2-input" id="css2-d2" value="600"> <span class="qt2-unit">yds/m</span>
      </div>
      <div class="qt2-field-group">
        <label>Long Time</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="css2-t2-min" value="10"> <span>min</span>
          <input type="number" class="qt2-input" id="css2-t2-sec" value="25"> <span>sec</span>
        </div>
      </div>
      <button class="qt2-calc-btn" data-calc="css2">Calculate</button>
      <div class="qt2-results" id="css2-results"></div>
    </div>
  </div>
</div>

<!-- ===================== SWIM INTERVAL PACING ===================== -->
<div class="qt2-panel" id="tab-swim-interval">
  <h2 class="qt2-calc-title">Swim Interval Pacing</h2>
  <p class="qt2-instructions">Enter athlete's Critical Speed pace (mm:ss per 100 yards/meters) to generate interval target paces for standard distances across training zones.</p>
  <div class="qt2-card">
    <div class="qt2-inline-fields">
      <div class="qt2-field-group">
        <label>Critical Speed Pace (/100 yds or m)</label>
        <div class="qt2-time-row">
          <input type="number" class="qt2-input" id="sip-cs-min" value="1"> <span>min</span>
          <input type="number" class="qt2-input" id="sip-cs-sec" value="37"> <span>sec</span>
        </div>
      </div>
      <div class="qt2-field-group">
        <label>Custom Interval Distance (yds/m)</label>
        <input type="number" class="qt2-input" id="sip-custom" value="75">
      </div>
    </div>
    <button class="qt2-calc-btn" data-calc="sip">Calculate</button>
    <div class="qt2-results" id="sip-results"></div>
  </div>
</div>

<!-- ===================== LOW CADENCE ===================== -->
<div class="qt2-panel" id="tab-low-cadence">
  <h2 class="qt2-calc-title">Low Cadence Calculator</h2>
  <p class="qt2-instructions">For athletes working on bike limiters where running has gotten ahead of cycling. These athletes often have difficulty getting HR up on the bike. Use for training and race-day cadence targets.</p>
  <div class="qt2-card">
    <div class="qt2-inline-fields">
      <div class="qt2-field-group">
        <label>Male / Female</label>
        <select class="qt2-select" id="lc-gender">
          <option value="male">Male</option>
          <option value="female" selected>Female</option>
        </select>
      </div>
      <div class="qt2-field-group">
        <label>Athlete's Typical Cadence</label>
        <input type="number" class="qt2-input" id="lc-cadence" value="80"> <span class="qt2-unit">rpm</span>
      </div>
      <div class="qt2-field-group">
        <label>Critical Power</label>
        <input type="number" class="qt2-input" id="lc-cp" value="135"> <span class="qt2-unit">watts</span>
      </div>
    </div>
    <button class="qt2-calc-btn" data-calc="lc">Calculate</button>
    <div class="qt2-results" id="lc-results"></div>
  </div>
</div>

<!-- ===================== CHO BURN SWIM ===================== -->
<div class="qt2-panel" id="tab-cho-swim">
  <h2 class="qt2-calc-title">CHO Burn Calculator (Swim)</h2>
  <p class="qt2-instructions">Estimate total carbohydrate need for a swim session. Enter body weight, swim nature, distance, and approximate pace.</p>
  <div class="qt2-card">
    <div class="qt2-inline-fields">
      <div class="qt2-field-group">
        <label>Body Weight</label>
        <input type="number" class="qt2-input" id="chos-weight" value="121"> <span class="qt2-unit">lbs</span>
      </div>
      <div class="qt2-field-group">
        <label>Nature of Swim</label>
        <select class="qt2-select" id="chos-nature">
          <option value="easy">Easy/Recovery (MET 6)</option>
          <option value="moderate">Moderate Steady (MET 8)</option>
          <option value="intervals" selected>High Intensity Intervals (MET 11)</option>
          <option value="race">Race Pace (MET 13)</option>
        </select>
