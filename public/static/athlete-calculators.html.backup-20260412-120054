  /* ====================================================
     CHO BURN — SWIM
     ==================================================== */
  function calcCHOSwim() {
    var weight   = num('chos-weight');
    var distance = num('chos-distance');
    var paceEl   = el('chos-pace');
    var pace     = paceEl ? parseFloat(paceEl.value) : 0;
    var natureEl = el('chos-nature');
    var nature   = natureEl ? natureEl.value : 'moderate';
    if (!isFinitePositive(weight) || !isFinitePositive(distance) || !isFinitePositive(pace)) return showError('chos-results','Enter all swim inputs.');
    var timeMinutes = ((distance / 100) * pace) / 60;
    var METmap = { easy: 6, moderate: 8, intervals: 11, race: 13 };
    var MET    = METmap[nature] || 8;
    var kg     = weight * 0.453592;
    var calories = MET * kg * (timeMinutes / 60);
    var carbs    = (calories * 0.5) / 4;
    var gels     = carbs / 30;
    renderResult('chos-results',
      renderResultBox('CHO Burn (Swim)',
        '<div class="qt2-result-grid">' +
        makeStat('Duration', timeMinutes.toFixed(1), 'min')     +
        makeStat('Calories', calories.toFixed(0),    'kcal')    +
        makeStat('CHO Burned', carbs.toFixed(1),     'g')       +
        makeStat('Fuel Equivalent', gels.toFixed(1), 'C30 gels')+
        '</div>')
    );
  }

