     ==================================================== */
  function calcHeatHumidity_UNUSED() {
    var watts    = parseFloat(document.getElementById('hh-watts') ? document.getElementById('hh-watts').value : '') || 0;
    var paceMin  = intVal('hh-pace-min', -1);
    var paceSec  = intVal('hh-pace-sec', -1);
    var hr       = parseFloat(document.getElementById('hh-hr') ? document.getElementById('hh-hr').value : '') || 0;
    var temp     = parseInt((document.getElementById('hh-temp') || {}).value || '0', 10);
    var humid    = parseInt((document.getElementById('hh-humid') || {}).value || '0', 10);

    var hasPace  = (paceMin >= 0 && paceSec >= 0 && (paceMin > 0 || paceSec > 0));
    var hasWatts = isFinitePositive(watts);
    var hasHR    = isFinitePositive(hr);

    if (!hasWatts && !hasPace && !hasHR) {
      return showError('hh-results', 'Enter at least one target metric (wattage, pace, or heart rate).');
    }

    /* --- Degradation lookup table (% degradation) --- */
    var t = temp, h = humid;
    var deg =
      (t===0  && h===0)  ? 0 :
      (t===0  && h===5)  ? 0 :
      (t===0  && h===10) ? 1 :
      (t===0  && h===15) ? 2 :
      (t===0  && h===20) ? 2 :
      (t===5  && h===0)  ? 0 :
      (t===5  && h===5)  ? 1 :
      (t===5  && h===10) ? 2 :
      (t===5  && h===15) ? 2 :
      (t===5  && h===20) ? 2 :
      (t===10 && h===0)  ? 2 :
      (t===10 && h===5)  ? 2 :
      (t===10 && h===10) ? 3 :
      (t===10 && h===15) ? 3 :
      (t===10 && h===20) ? 3 :
      (t===15 && h===0)  ? 4 :
      (t===15 && h===5)  ? 4 :
      (t===15 && h===10) ? 5 :
      (t===15 && h===15) ? 5 :
      (t===15 && h===20) ? 5 :
      (t===20 && h===0)  ? 6 :
      (t===20 && h===5)  ? 6 :
      (t===20 && h===10) ? 6 :
      (t===20 && h===15) ? 7 :
      (t===20 && h===20) ? 7 : 0;

    /* --- Adjustment multipliers --- */
    /* Wattage: reduce by deg%  (e.g. deg=3 → ×0.97) */
    /* Pace:    slow by deg%    (e.g. deg=3 → ×1.03) */
    /* HR:      raise by 0.8×deg% (e.g. deg=3 → ×(1+0.024)) */
    var wattMult = 1 - (deg / 100);
    var paceMult = 1 + (deg / 100);
    var hrMult   = 1 + (0.8 * deg / 100);

    var statGrid = '<div class="qt2-result-grid">' +
      makeStat('Degradation', deg, '%') +
      makeStat('Temp Delta', temp + '\u00b0F') +
      makeStat('Humidity Delta', humid + '%') +
    '</div>';

    var output = renderResultBox('Conditions Summary', statGrid);

    if (hasWatts) {
      var adjWatts = Math.round(watts * wattMult);
      output += '<div style="height:12px;"></div>' +
        renderResultBox('Adjusted Target Wattage',
          '<div class="qt2-result-grid">' +
          makeStat('Original', Math.round(watts), 'W') +
          makeStat('Adjusted', adjWatts, 'W') +
          makeStat('Reduction', (Math.round(watts) - adjWatts), 'W') +
          '</div>');
    }

    if (hasPace) {
      var origTotalSec = (paceMin * 60) + paceSec;
      var adjTotalSec  = Math.round(origTotalSec * paceMult);
      var adjMin = Math.floor(adjTotalSec / 60);
      var adjSec = adjTotalSec % 60;
      var origFmt = paceMin + ':' + pad(paceSec);
      var adjFmt  = adjMin  + ':' + pad(adjSec);
      var slowSec = adjTotalSec - origTotalSec;
      output += '<div style="height:12px;"></div>' +
        renderResultBox('Adjusted Target Pace',
          '<div class="qt2-result-grid">' +
          makeStat('Original', origFmt, '/mi') +
          makeStat('Adjusted', adjFmt,  '/mi') +
          makeStat('Slower by', slowSec, 'sec/mi') +
          '</div>');
    }

    if (hasHR) {
      var adjHR = Math.round(hr * hrMult);
      output += '<div style="height:12px;"></div>' +
        renderResultBox('Adjusted Target Heart Rate',
          '<div class="qt2-result-grid">' +
          makeStat('Original', Math.round(hr), 'bpm') +
          makeStat('Adjusted', adjHR,           'bpm') +
          makeStat('Increase', (adjHR - Math.round(hr)), 'bpm') +
          '</div>');
    }

    if (deg === 0) {
      output += '<div style="height:12px;"></div><div class="qt2-highlight-box">No adjustment needed &mdash; conditions are similar to your training environment.</div>';
    }

    renderResult('hh-results', output);
  }

  /* ====================================================
     HEAT & HUMIDITY ADJUSTMENT
     ==================================================== */
  function calcHeatHumidity() {
    var wattsRaw = num('hh-watts', 0);
    var paceMin  = intVal('hh-pace-min', -1);
    var paceSec  = intVal('hh-pace-sec', -1);
    var hrRaw    = num('hh-hr', 0);
    var tempDelta  = parseInt((el('hh-temp')  ? el('hh-temp').value  : '0'), 10);
    var humidDelta = parseInt((el('hh-humid') ? el('hh-humid').value : '0'), 10);

    /* Require at least one target metric */
    var hasWatts = isFinitePositive(wattsRaw);
    var hasPace  = (paceMin >= 0 && paceSec >= 0 && (paceMin * 60 + paceSec) > 0);
    var hasHR    = isFinitePositive(hrRaw);

    if (!hasWatts && !hasPace && !hasHR) {
      return showError('hh-results', 'Please enter at least one target metric (Wattage, Pace, or Heart Rate).');
    }

    /* ---- Degradation lookup table (%) ---- */
    /* Keys: tempDelta × 100 + humidDelta (e.g. temp=10,humid=15 → key 1015) */
    var lookup = {
         0: 0,    5: 0,   10: 1,   15: 2,   20: 2,   /* temp 0  */
       500: 0,  505: 1,  510: 2,  515: 2,  520: 2,   /* temp 5  */
      1000: 2, 1005: 2, 1010: 3, 1015: 3, 1020: 3,   /* temp 10 */
      1500: 4, 1505: 4, 1510: 5, 1515: 5, 1520: 5,   /* temp 15 */
      2000: 6, 2005: 6, 2010: 6, 2015: 7, 2020: 7    /* temp 20 */
    };

    /* Clamp inputs to table boundaries */
    var t = Math.min(tempDelta,  20);
    var h = Math.min(humidDelta, 20);
    var key = t * 100 + h;
    var degradation = (lookup[key] !== undefined) ? lookup[key] : 0;
    var factor = degradation / 100;

    /* ---- Build result HTML ---- */
    var statGrid = '<div class="qt2-result-grid">' +
      makeStat('Degradation', degradation, '% estimated') +
    '</div>';

    var outputSections = '';

    /* Wattage: multiply by (1 - factor) */
    if (hasWatts) {
      var adjWatts = Math.round(wattsRaw * (1 - factor));
      outputSections += '<div style="height:12px;"></div>' +
        renderResultBox('Adjusted Target Wattage',
          '<div class="qt2-result-grid">' +
          makeStat('Original', Math.round(wattsRaw), 'W') +
          makeStat('Adjusted', adjWatts, 'W') +
          makeStat('Reduction', Math.round(wattsRaw) - adjWatts, 'W') +
          '</div>');
    }

    /* Pace: multiply total seconds by (1 + factor) — slower pace = more seconds/mile */
    if (hasPace) {
      var origTotalSec = paceMin * 60 + paceSec;
      var adjTotalSec  = Math.round(origTotalSec * (1 + factor));
      var adjPaceMin   = Math.floor(adjTotalSec / 60);
      var adjPaceSec   = adjTotalSec % 60;
      outputSections += '<div style="height:12px;"></div>' +
        renderResultBox('Adjusted Target Pace',
          '<div class="qt2-result-grid">' +
          makeStat('Original', paceMin + ':' + pad(paceSec), '/mi') +
          makeStat('Adjusted', adjPaceMin + ':' + pad(adjPaceSec), '/mi') +
          makeStat('Slowdown', '+' + (adjTotalSec - origTotalSec), 'sec/mi') +
          '</div>');
    }

    /* Heart Rate: multiply by (1 + 0.8 × factor) — HR rises in heat */
    if (hasHR) {
      var adjHR = Math.round(hrRaw * (1 + 0.8 * factor));
      outputSections += '<div style="height:12px;"></div>' +
        renderResultBox('Adjusted Target Heart Rate',
          '<div class="qt2-result-grid">' +
          makeStat('Original', Math.round(hrRaw), 'bpm') +
          makeStat('Adjusted', adjHR, 'bpm') +
          makeStat('Increase', '+' + (adjHR - Math.round(hrRaw)), 'bpm') +
          '</div>');
    }

    /* Interpretation note */
    var note = degradation === 0
      ? 'No significant performance impact expected for these conditions.'
      : 'In hotter/more humid conditions your body works harder to cool itself, reducing available power and elevating heart rate. Adjust your effort to the new targets to race/train at an equivalent physiological load.';

    outputSections += '<div style="height:12px;"></div>' +
      renderResultBox('Interpretation', '<div style="font-size:13px;line-height:1.6;">' + note + '</div>');

    renderResult('hh-results',
      renderResultBox('Condition Summary', statGrid) +
      outputSections
    );
  }

  /* ====================================================
     TRAINING ZONES — live dual-input back-calc
     ==================================================== */
  function updateTrainingZones() {

    /* --- Bike Power --- */
    var bikeCPdirect = num('tz-bike-ftp', 0);
    var bikeZ1top    = num('tz-bike-z1top', 0);
    var bikeCP = 0;
    if (isFinitePositive(bikeCPdirect))   bikeCP = bikeCPdirect;
    else if (isFinitePositive(bikeZ1top)) bikeCP = bikeZ1top / 0.79;
    if (isFinitePositive(bikeCP)) {
      bikeCP = Math.round(bikeCP);
      setText('tz-bike-cp-used', bikeCP);
      setText('tz-bike-zr', '< '+ Math.round(bikeCP*0.65) +' W');
      setText('tz-bike-z1', Math.round(bikeCP*0.65) +'–'+ Math.round(bikeCP*0.79) +' W');
      setText('tz-bike-z2', Math.round(bikeCP*0.79) +'–'+ Math.round(bikeCP*0.89) +' W');
      setText('tz-bike-z3', Math.round(bikeCP*0.89) +'–'+ Math.round(bikeCP)      +' W');
    }

    /* --- Run Power --- */
    var runCPdirect  = num('tz-run-ftp', 0);
    var runpZ1top    = num('tz-runp-z1top', 0);
    var runCP = 0;
    if (isFinitePositive(runCPdirect))    runCP = runCPdirect;
    else if (isFinitePositive(runpZ1top)) runCP = runpZ1top / 0.79;
    if (isFinitePositive(runCP)) {
      runCP = Math.round(runCP);
      setText('tz-runp-cp-used', runCP);
      setText('tz-runp-zr', '< '+ Math.round(runCP*0.65) +' W');
      setText('tz-runp-z1', Math.round(runCP*0.65) +'–'+ Math.round(runCP*0.79) +' W');
      setText('tz-runp-z2', Math.round(runCP*0.79) +'–'+ Math.round(runCP*0.89) +' W');
      setText('tz-runp-z3', Math.round(runCP*0.89) +'–'+ Math.round(runCP)      +' W');
    }

    /* --- Run Pace (CS)  --- */
    /* Z1 = 75–85% CS speed; top of Z1 pace = CS_pace / 0.85 → CS = Z1top_pace × 0.85 */
    var runCSdirect = parsePaceField('tz-run-cs');
    var runZ1topNode = el('tz-run-z1top');
    var runZ1top = runZ1topNode ? parseFlexibleTimeInput(runZ1topNode.value) : null;
    var runSec = 0;
    if (isFinitePositive(runCSdirect))   runSec = runCSdirect;
    else if (isFinitePositive(runZ1top)) runSec = runZ1top * 0.85;
    if (isFinitePositive(runSec)) {
      setText('tz-run-cs-used', secondsToPace(runSec, ''));
      setText('tz-run-mi-zr', '> ' + secondsToPace(runSec / 0.75, '/mi'));
      setText('tz-run-mi-z1', secondsToPace(runSec/0.85,'/mi') + ' – ' + secondsToPace(runSec/0.75,'/mi'));
      setText('tz-run-mi-z2', secondsToPace(runSec/0.95,'/mi') + ' – ' + secondsToPace(runSec/0.85,'/mi'));
      setText('tz-run-mi-z3', secondsToPace(runSec/1.00,'/mi') + ' – ' + secondsToPace(runSec/0.95,'/mi'));
      setText('tz-run-mi-z4', secondsToPace(runSec/1.10,'/mi') + ' – ' + secondsToPace(runSec/1.00,'/mi'));
      var runMps   = paceSecondsPerMileToMetersPerSecond(runSec);
      var kmBase   = metersPerSecondToSecondsPerKm(runMps);
      setText('tz-run-km-zr', '> ' + secondsToPace(kmBase / 0.75, '/km'));
      setText('tz-run-km-z1', secondsToPace(kmBase/0.85,'/km') + ' – ' + secondsToPace(kmBase/0.75,'/km'));
      setText('tz-run-km-z2', secondsToPace(kmBase/0.95,'/km') + ' – ' + secondsToPace(kmBase/0.85,'/km'));
      setText('tz-run-km-z3', secondsToPace(kmBase/1.00,'/km') + ' – ' + secondsToPace(kmBase/0.95,'/km'));
      setText('tz-run-km-z4', secondsToPace(kmBase/1.10,'/km') + ' – ' + secondsToPace(kmBase/1.00,'/km'));
    }

    /* --- Swim Pace (CSS) --- */
    /* Z1 = 90–95% CSS speed; top of Z1 pace = CSS_pace / 0.95 → CSS = Z1top_pace × 0.95 */
    var swimCSdirect = parsePaceField('tz-swim-cs');
    var swimZ1topNode = el('tz-swim-z1top');
    var swimZ1top = swimZ1topNode ? parseFlexibleTimeInput(swimZ1topNode.value) : null;
    var swimSec = 0;
    if (isFinitePositive(swimCSdirect))   swimSec = swimCSdirect;
    else if (isFinitePositive(swimZ1top)) swimSec = swimZ1top * 0.95;
    if (isFinitePositive(swimSec)) {
      setText('tz-swim-cs-used', secondsToPace(swimSec, ''));
      setText('tz-swim-zr', '> ' + secondsToPace(swimSec / 0.90, '/100'));
      setText('tz-swim-z1', secondsToPace(swimSec/0.95,'/100') + ' – ' + secondsToPace(swimSec/0.90,'/100'));
      setText('tz-swim-z2', secondsToPace(swimSec/0.99,'/100') + ' – ' + secondsToPace(swimSec/0.95,'/100'));
      setText('tz-swim-z3', secondsToPace(swimSec/1.02,'/100') + ' – ' + secondsToPace(swimSec/0.99,'/100'));
    }

    /* --- Heart Rate --- */
    var thr   = num('tz-hr-thr', 0);
    var z1mid = num('tz-hr-z1mid', 0);
    var threshold = 0;
    if (isFinitePositive(thr))   threshold = thr;
    else if (isFinitePositive(z1mid)) threshold = z1mid / 0.83;
    if (isFinitePositive(threshold)) {
      threshold = Math.round(threshold);
      setText('tz-hr-thr-used', threshold);
      setText('tz-hr-zr', '\u2264 '+ Math.round(threshold*0.76) +' bpm');
      setText('tz-hr-z1', Math.round(threshold*0.80) +'–'+ Math.round(threshold*0.86) +' bpm');
      setText('tz-hr-z2', Math.round(threshold*0.86) +'–'+ Math.round(threshold*0.93) +' bpm');
      setText('tz-hr-z3', Math.round(threshold*0.93) +'–'+ Math.round(threshold*1.00) +' bpm');
    }
  }

  /* ====================================================
     BIND ALL EVENTS
     ==================================================== */
  function bindAll() {
    /* Calculator buttons */
    document.querySelectorAll('[data-calc]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var k = btn.dataset.calc;
        if (k === 'cp2')      calcCP2();
        if (k === 'cp3')      calcCP3();
        if (k === 'bew')      calcBEW();
        if (k === 'lc')       calcLowCadence();
        if (k === 'csr2')     calcCSR2();
        if (k === 'csr3')     calcCSR3();
        if (k === 'bep2')     calcBEP2();
        if (k === 'chor')     calcCHORun();
        if (k === 'css2')     calcCSS2();
        if (k === 'css3')     calcCSS3();
        if (k === 'sip')      calcSIP();
        if (k === 'chob-kj')  calcCHOBikeKJ();
        if (k === 'chob-cho') calcCHOBikeCHO();
        if (k === 'chos')     calcCHOSwim();
        if (k === 'hh')       calcHeatHumidity();
        if (k === 'vo2b')     vo2bPrescribe();
        if (k === 'vo2r')     vo2rPrescribe();
      });
    });

    /* TOC "Open" buttons */
    document.querySelectorAll('.qt2-link-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.dataset.goto;
        document.querySelectorAll('.qt2-tab').forEach(function(t)   { t.classList.remove('active'); });
        document.querySelectorAll('.qt2-panel').forEach(function(p) { p.classList.remove('active'); });
        var tab   = document.querySelector('.qt2-tab[data-tab="' + target + '"]');
        var panel = document.getElementById('tab-' + target);
        if (tab)   tab.classList.add('active');
        if (panel) panel.classList.add('active');
      });
    });

    /* Live Training Zones updates */
    var tzIds = [
      'tz-bike-ftp','tz-bike-z1top',
      'tz-run-ftp', 'tz-runp-z1top',
      'tz-run-cs',  'tz-run-z1top',
      'tz-swim-cs', 'tz-swim-z1top',
      'tz-hr-thr',  'tz-hr-z1mid'
    ];
    tzIds.forEach(function(id) {
      var node = el(id);
      if (node) node.addEventListener('input', updateTrainingZones);
    });

    /* Live Power Zones (Expanded) updates */
    var pzIds = ['pz-cp', 'pz-lt1', 'pz-ogc'];
    pzIds.forEach(function(id) {
      var node = el(id);
      if (node) node.addEventListener('input', renderPowerZones);
    });
  }

  /* ====================================================
     INIT
     ==================================================== */
  function init() {
    initTabs();
    bindAll();
    updateTrainingZones();
    renderPowerZones(); // Initialize expanded power zones calculator
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
</script>

