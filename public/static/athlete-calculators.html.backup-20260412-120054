(function () {
  'use strict';

  var METERS_PER_MILE = 1609.344;
  var METERS_PER_KM   = 1000;

  /* ---- DOM helpers ---- */
  function el(id) { return document.getElementById(id); }
  function num(id, fallback) {
    if (fallback === undefined) fallback = 0;
    var node = el(id);
    if (!node) return fallback;
    var v = parseFloat(node.value);
    return Number.isFinite(v) ? v : fallback;
  }
  function intVal(id, fallback) {
    if (fallback === undefined) fallback = 0;
    var node = el(id);
    if (!node) return fallback;
    var v = parseInt(node.value, 10);
    return Number.isFinite(v) ? v : fallback;
  }
  function isFinitePositive(n) { return Number.isFinite(n) && n > 0; }

  /* ---- Time / pace helpers ---- */
  function parseFlexibleTimeInput(val) {
    if (val == null) return null;
    val = String(val).trim();
    if (!val) return null;
    if (val.indexOf(':') !== -1) {
      var parts = val.split(':');
      var m = Number(parts[0]), s = Number(parts[1]);
      if (Number.isFinite(m) && Number.isFinite(s)) return (m * 60) + s;
    }
    var dec = parseFloat(val);
    if (Number.isFinite(dec)) return dec * 60;
    return null;
  }
  function parsePaceField(id) {
    var node = el(id);
    if (!node) return null;
    return parseFlexibleTimeInput(node.value);
  }
  function parseMinSecPair(minId, secId) {
    var m = intVal(minId, 0), s = intVal(secId, 0);
    var total = (m * 60) + s;
    return total > 0 ? total : null;
  }

  function secondsToClock(totalSeconds) {
    if (!Number.isFinite(totalSeconds) || totalSeconds < 0) return '—';
    var secs = Math.round(totalSeconds);
    var h = Math.floor(secs / 3600); secs -= h * 3600;
    var m = Math.floor(secs / 60);   secs -= m * 60;
    if (h > 0) return h + ':' + pad(m) + ':' + pad(secs);
    return m + ':' + pad(secs);
  }
  function pad(n) { return String(n).length < 2 ? '0' + n : String(n); }

  function secondsToPace(sec, suffix) {
    if (suffix === undefined) suffix = '/mi';
    if (!isFinitePositive(sec)) return '—';
    var m = Math.floor(sec / 60);
    var s = Math.round(sec % 60);
    if (s === 60) { s = 0; m += 1; }
    return m + ':' + pad(s) + suffix;
  }

  function paceSecondsPerMileToMetersPerSecond(secPerMile) { return METERS_PER_MILE / secPerMile; }
  function metersPerSecondToSecondsPerMile(mps)            { return METERS_PER_MILE / mps; }
  function metersPerSecondToSecondsPerKm(mps)              { return METERS_PER_KM   / mps; }
  function paceForPercentOfSpeed(baseSec, pct)             { return baseSec / pct; }

  /* ---- Least-squares regression ---- */
  function leastSquaresSlopeIntercept(xs, ys) {
    var n = xs.length;
    if (n !== ys.length || n < 2) return null;
    var sx = 0, sy = 0, sxy = 0, sxx = 0;
    for (var i = 0; i < n; i++) { sx += xs[i]; sy += ys[i]; sxy += xs[i] * ys[i]; sxx += xs[i] * xs[i]; }
    var denom = (n * sxx) - (sx * sx);
    if (denom === 0) return null;
    var slope     = ((n * sxy) - (sx * sy)) / denom;
    var intercept = (sy - slope * sx) / n;
    return { slope: slope, intercept: intercept };
  }

