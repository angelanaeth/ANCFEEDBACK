  display: none;
  padding: 28px 24px;
  background: var(--qt2-bg);
  border-radius: 0 0 10px 10px;
}
.qt2-panel.active { display: block; }

/* ---- Typography ---- */
.qt2-main-title  { font-size: 30px; font-weight: 800; color: var(--qt2-primary); margin: 0 0 6px; }
.qt2-subtitle    { font-size: 15px; color: var(--qt2-muted); margin: 0 0 24px; }
.qt2-calc-title  { font-size: 24px; font-weight: 700; color: var(--qt2-primary); margin: 0 0 10px; }
.qt2-instructions {
  background: #fffbeb;
  border-left: 4px solid #f59e0b;
  padding: 12px 16px;
  border-radius: 4px;
  font-size: 14.5px;
  color: #44403c;
  margin-bottom: 22px;
  line-height: 1.7;
}

/* ---- Layout ---- */
.qt2-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 700px) {
  .qt2-two-col { grid-template-columns: 1fr; }
}
.qt2-inline-fields {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  margin-bottom: 16px;
}

/* ---- Cards ---- */
.qt2-card {
  background: var(--qt2-card);
  border: 1px solid var(--qt2-border);
  border-radius: 10px;
  padding: 22px 20px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.qt2-card h3 {
  font-size: 16px;
  font-weight: 700;
  color: var(--qt2-primary);
  margin: 0 0 16px;
  padding-bottom: 8px;
  border-bottom: 2px solid var(--qt2-input-bg);
}

/* ---- Field groups ---- */
.qt2-field-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 12px;
}
.qt2-field-group label {
  font-size: 13px;
  font-weight: 600;
  color: var(--qt2-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.qt2-time-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.qt2-time-row span { font-size: 13px; color: var(--qt2-muted); }

/* ---- Inputs ---- */
.qt2-input {
  background: var(--qt2-input-bg);
  border: 1.5px solid #93c5fd;
  border-radius: 6px;
  padding: 8px 10px;
  font-size: 15px;
  font-weight: 600;
  color: var(--qt2-text);
  width: 80px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
}
.qt2-input:focus {
  border-color: var(--qt2-accent);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
}
.qt2-input--wide { width: 110px; }
.qt2-unit  { font-size: 13px; color: var(--qt2-muted); margin-left: 4px; }

/* ---- Select ---- */
.qt2-select {
  background: var(--qt2-input-bg);
  border: 1.5px solid #93c5fd;
  border-radius: 6px;
  padding: 8px 10px;
  font-size: 14px;
  font-weight: 500;
  color: var(--qt2-text);
  outline: none;
  min-width: 200px;
  box-sizing: border-box;
}

/* ---- Buttons ---- */
.qt2-calc-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--qt2-accent);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 11px 24px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  margin-top: 8px;
  transition: background 0.18s, transform 0.1s;
  letter-spacing: 0.01em;
}
.qt2-calc-btn:hover  { background: #1d4ed8; transform: translateY(-1px); }
.qt2-calc-btn:active { transform: translateY(0); }

.qt2-link-btn {
  background: var(--qt2-accent);
  color: #fff;
  border: none;
  border-radius: 5px;
  padding: 5px 14px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s;
}
.qt2-link-btn:hover { background: #1d4ed8; }

/* ---- Results area ---- */
.qt2-results { margin-top: 18px; }

.qt2-result-box {
  background: var(--qt2-result-bg);
  border: 1.5px solid var(--qt2-result-border);
  border-radius: 8px;
  padding: 16px 18px;
}
.qt2-result-box h4 {
  font-size: 13px;
  font-weight: 700;
  color: var(--qt2-accent);
  margin: 0 0 12px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.qt2-result-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 10px;
  margin-bottom: 14px;
}
.qt2-stat {
  background: #fff;
  border: 1px solid #bfdbfe;
  border-radius: 6px;
  padding: 10px 12px;
}
.qt2-stat-label { font-size: 12px; color: var(--qt2-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
.qt2-stat-value { font-size: 22px; font-weight: 800; color: var(--qt2-primary); margin-top: 2px; }
.qt2-stat-unit  { font-size: 12px; color: var(--qt2-muted); font-weight: 500; }

/* ---- Result tables ---- */
.qt2-result-table { width: 100%; border-collapse: collapse; font-size: 14px; margin-top: 10px; }
.qt2-result-table th { background: var(--qt2-primary); color: #fff; padding: 8px 12px; text-align: left; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; }
.qt2-result-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; }
.qt2-result-table tr:last-child td { border-bottom: none; }
.qt2-result-table tr:nth-child(even) td { background: #f8fafc; }

.qt2-highlight-box {
  background: #ecfdf5;
  border: 2px solid #16a34a;
  border-radius: 8px;
  padding: 14px 16px;
  margin-top: 12px;
  font-size: 15px;
  font-weight: 700;
  color: #14532d;
}

/* ---- Table of Contents table ---- */
.qt2-toc-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 10px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.07); }
.qt2-toc-table th { background: var(--qt2-primary); color: #fff; padding: 12px 16px; text-align: left; font-size: 14px; }
.qt2-toc-table td { padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-size: 15px; }
.qt2-toc-table tr:last-child td { border-bottom: none; }
.qt2-toc-table tr:hover td { background: #f0f9ff; }

/* ---- Zone colour codes ---- */
.zone-zr { color: #dc2626; font-weight: 700; }
.zone-z1 { color: #d97706; font-weight: 700; }
.zone-z2 { color: #65a30d; font-weight: 700; }
.zone-z3 { color: #2563eb; font-weight: 700; }
.zone-z4 { color: #7c3aed; font-weight: 700; }

/* ---- Training Zones grid ---- */
.qt2-zones-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}
.qt2-zones-card--full { grid-column: 1 / -1; }

.qt2-zones-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--qt2-input-bg);
}
.qt2-zones-card-header h3 {
  font-size: 15px;
  font-weight: 700;
  color: var(--qt2-primary);
  margin: 0;
  border: none;
  padding: 0;
}

.qt2-zone-tag {
  font-size: 10px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.qt2-zone-tag--bike { background: #dbeafe; color: #1e40af; }
.qt2-zone-tag--run  { background: #dcfce7; color: #15803d; }
.qt2-zone-tag--swim { background: #e0f2fe; color: #0369a1; }
.qt2-zone-tag--hr   { background: #fee2e2; color: #b91c1c; }

.qt2-tz-used { font-size: 12px; color: #64748b; margin: 0 0 10px; }

.qt2-zones-table-wrap {
  border: 1px solid var(--qt2-border);
  border-radius: 8px;
  overflow: hidden;
  margin-top: 10px;
}
.qt2-zones-table { width: 100%; border-collapse: collapse; font-size: 14.5px; }
.qt2-zones-table th {
  background: var(--qt2-primary);
  color: #fff;
  padding: 9px 12px;
  text-align: left;
  font-size: 12px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-weight: 600;
}
.qt2-zones-table td { padding: 10px 12px; border-bottom: 1px solid #e8edf4; vertical-align: middle; }
.qt2-zones-table tr:last-child td { border-bottom: none; }
.qt2-zones-table tr:nth-child(even) td { background: #f8fafc; }
.qt2-zones-table .num-cell {
  font-family: ui-monospace, 'Courier New', monospace;
  font-size: 13px;
  text-align: right;
  font-weight: 600;
  color: var(--qt2-primary);
}

@media (max-width: 680px) {
  .qt2-zones-grid { grid-template-columns: 1fr; }
}

/* ============================================================
   VO2 PRESCRIBER — Styles (uses existing qt2 variables)
   ============================================================ */

/* Sport sub-tab bar */
.vo2-sport-tabs {
  display: flex;
  gap: 0;
  margin-bottom: 20px;
  border-radius: 8px;
  overflow: hidden;
  border: 1.5px solid var(--qt2-border);
  width: fit-content;
}
.vo2-sport-tab {
  background: #f8fafc;
  border: none;
  padding: 10px 28px;
  font-size: 15px;
  font-weight: 600;
  color: var(--qt2-muted);
  cursor: pointer;
  transition: background 0.18s, color 0.18s;
  letter-spacing: 0.01em;
}
.vo2-sport-tab + .vo2-sport-tab { border-left: 1.5px solid var(--qt2-border); }
.vo2-sport-tab.active {
  background: var(--qt2-primary);
  color: #fff;
}
.vo2-sport-tab:hover:not(.active) {
  background: var(--qt2-input-bg);
  color: var(--qt2-primary);
}

/* Durability toggle for Run */
.vo2r-dur-row {
  display: flex;
  border: 1.5px solid #93c5fd;
  border-radius: 6px;
  overflow: hidden;
  background: var(--qt2-input-bg);
}
.vo2r-dur-btn {
  flex: 1;
  background: transparent;
  border: none;
  padding: 7px 14px;
  font-size: 13px;
  font-weight: 600;
  color: var(--qt2-muted);
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.vo2r-dur-btn + .vo2r-dur-btn { border-left: 1.5px solid #93c5fd; }
.vo2r-dur-btn.active-std {
  background: #dcfce7;
  color: #15803d;
}
.vo2r-dur-btn.active-dur {
  background: #dbeafe;
  color: #1e40af;
}

/* Workout output card */
.vo2-workout-card {
  background: var(--qt2-card);
  border: 1.5px solid var(--qt2-border);
  border-radius: 10px;
  overflow: hidden;
  margin-top: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

/* Workout header strip */
.vo2-workout-header {
  background: var(--qt2-primary);
  color: #fff;
  padding: 16px 20px;
}
.vo2-workout-protocol {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  margin-bottom: 4px;
}
.vo2-workout-name {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.01em;
}
.vo2-workout-goal {
  font-size: 13px;
  color: rgba(255,255,255,0.75);
  margin-top: 6px;
  line-height: 1.5;
}

/* Structure badges inside header */
.vo2-badge-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
.vo2-structure-badge {
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 5px;
  padding: 6px 12px;
  font-size: 13px;
  font-family: ui-monospace, 'Courier New', monospace;
  color: #fff;
}
.vo2-tss-badge {
  background: rgba(251,191,36,0.18);
  border: 1px solid rgba(251,191,36,0.4);
  border-radius: 5px;
  padding: 6px 12px;
  display: inline-flex;
  align-items: baseline;
  gap: 5px;
}
.vo2-tss-value {
  font-size: 18px;
  font-weight: 800;
  color: #fbbf24;
  font-family: ui-monospace, 'Courier New', monospace;
}
.vo2-tss-label { font-size: 11px; color: #92400e; font-weight: 700; }

/* Profile card (under stats) */
.vo2-profile-card {
  border-radius: 8px;
  padding: 14px 18px;
  margin-bottom: 16px;
  border: 1.5px solid;
}
.vo2-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-right: 6px;
  margin-bottom: 8px;
}
.vo2-profile-text { font-size: 14px; color: #374151; line-height: 1.6; }
.vo2-profile-note { font-size: 12.5px; color: var(--qt2-muted); line-height: 1.6; margin-top: 6px; }

/* Workout internal tabs (Workout 1 / Workout 2) */
.vo2-wkt-tabs {
  display: flex;
  border-bottom: 2px solid var(--qt2-border);
  background: #f8fafc;
  margin-bottom: 0;
}
.vo2-wkt-tab {
  background: transparent;
  border: none;
  border-bottom: 3px solid transparent;
  padding: 11px 20px;
  font-size: 14px;
  font-weight: 600;
  color: var(--qt2-muted);
  cursor: pointer;
  margin-bottom: -2px;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}
.vo2-wkt-tab.active {
  color: var(--qt2-primary);
  border-bottom-color: var(--qt2-accent);
}
.vo2-wkt-tab:hover:not(.active) { color: var(--qt2-primary); }

/* Body two-column */
.vo2-body-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border-top: 1px solid var(--qt2-border);
}
@media (max-width: 700px) {
  .vo2-body-inner { grid-template-columns: 1fr; }
}
.vo2-body-col {
  padding: 18px 20px;
  border-right: 1px solid var(--qt2-border);
}
.vo2-body-col:last-child { border-right: none; }

/* Section labels inside body */
.vo2-section-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--qt2-muted);
  margin-bottom: 10px;
  margin-top: 16px;
}
.vo2-section-label:first-child { margin-top: 0; }

/* Detail rows */
.vo2-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 7px 0;
  border-bottom: 1px solid #f1f5f9;
  gap: 12px;
  font-size: 14px;
}
.vo2-detail-row:last-child { border-bottom: none; }
.vo2-detail-key { color: var(--qt2-muted); font-weight: 500; flex-shrink: 0; }
.vo2-detail-val { color: var(--qt2-primary); font-weight: 700; text-align: right; font-family: ui-monospace,'Courier New',monospace; }

/* List items (progression / cues / flags) */
.vo2-list-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 5px 0;
  font-size: 14px;
  color: #374151;
  line-height: 1.5;
}
.vo2-flag-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 5px 0;
  font-size: 13px;
  color: #b45309;
  line-height: 1.5;
}
.vo2-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  margin-top: 5px;
  flex-shrink: 0;
}

/* Primer box */
.vo2-primer-box {
  background: #eff6ff;
  border: 1.5px solid #93c5fd;
  border-radius: 7px;
  padding: 12px 14px;
  margin-bottom: 14px;
}
.vo2-primer-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--qt2-accent);
  margin-bottom: 8px;
}
.vo2-primer-step {
  font-size: 13px;
  color: #1e40af;
  padding: 2px 0;
  line-height: 1.5;
  font-family: ui-monospace,'Courier New',monospace;
}
.vo2-primer-cost { font-size: 12px; color: var(--qt2-muted); margin-top: 6px; }

/* Run warning box */
.vo2-run-warn {
  background: #fff7ed;
  border: 1.5px solid #fdba74;
  border-radius: 7px;
  padding: 12px 14px;
  margin-bottom: 14px;
  font-size: 13px;
  color: #92400e;
  line-height: 1.6;
}
.vo2-run-warn-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: #ea580c;
  margin-bottom: 6px;
}

/* Durability notice bar */
.vo2-dur-notice {
  border-radius: 7px;
  padding: 12px 16px;
  margin-bottom: 16px;
  font-size: 13.5px;
  line-height: 1.6;
}
.vo2-dur-notice.standard {
  background: #f0fdf4;
  border: 1.5px solid #86efac;
  color: #15803d;
}
.vo2-dur-notice.durable {
  background: #eff6ff;
  border: 1.5px solid #93c5fd;
  color: #1e40af;
}

/* Range cards (Run std/durable) */
.vo2-range-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px; }
@media (max-width: 500px) { .vo2-range-row { grid-template-columns: 1fr; } }
.vo2-range-card {
  border-radius: 7px;
  padding: 12px 14px;
  border: 1.5px solid;
  font-size: 13px;
}
.vo2-range-card.std {
  background: #f0fdf4;
  border-color: #86efac;
}
.vo2-range-card.dur {
  background: #eff6ff;
  border-color: #93c5fd;
}
.vo2-range-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.vo2-range-card.std .vo2-range-label { color: #15803d; }
.vo2-range-card.dur .vo2-range-label { color: #1e40af; }
.vo2-range-struct {
  font-family: ui-monospace,'Courier New',monospace;
  font-size: 13px;
  color: var(--qt2-primary);
  line-height: 1.5;
  margin-bottom: 4px;
}

/* Error message for VO2 */
.vo2-error {
  background: #fef2f2;
  border: 1.5px solid #fca5a5;
  border-radius: 6px;
  padding: 10px 14px;
  margin-top: 10px;
  font-size: 14px;
  color: #b91c1c;
  display: none;
}

/* VO2 stat grid — reuses qt2-result-grid / qt2-stat but bigger values */
.vo2-stat-value { font-size: 22px; font-weight: 800; color: var(--qt2-primary); margin-top: 2px; }

/* ============================================================
   TH BIKE ANALYSIS — Additional styles
   ============================================================ */

/* Drop zone */
.tha-drop-zone {
  border: 2px dashed var(--qt2-border);
  border-radius: 10px;
  padding: 32px 24px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  position: relative;
  margin-bottom: 16px;
  background: var(--qt2-card);
}
.tha-drop-zone:hover, .tha-drop-zone.drag {
  border-color: var(--qt2-accent);
  background: #eff6ff;
}
.tha-drop-zone input {
  position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
.tha-dz-icon {
  font-size: 28px; color: var(--qt2-accent); margin-bottom: 8px;
}
.tha-dz-title { font-size: 15px; font-weight: 600; color: var(--qt2-primary); margin-bottom: 4px; }
.tha-dz-sub { font-size: 12.5px; color: var(--qt2-muted); }

/* Status / diag */
.tha-status-bar {
  background: var(--qt2-result-bg);
  border: 1px solid var(--qt2-result-border);
  border-radius: 6px;
  padding: 9px 14px;
  font-size: 13px;
  color: var(--qt2-muted);
  margin-bottom: 10px;
  display: none;
  align-items: center;
  gap: 8px;
}
.tha-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--qt2-accent);
  animation: thaPulse 1.4s infinite; flex-shrink: 0;
}
@keyframes thaPulse { 0%,100%{opacity:1} 50%{opacity:0.2} }

.tha-diag {
  border-radius: 8px;
  margin-bottom: 16px;
  overflow: hidden;
  display: none;
  border: 1.5px solid var(--qt2-border);
}
.tha-diag-hdr {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--qt2-border);
  background: var(--qt2-result-bg);
}
.tha-diag-icon {
  width: 24px; height: 24px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700; flex-shrink: 0;
}
.tha-di-ok   { background: #dcfce7; color: #15803d; }
.tha-di-warn { background: #fef9c3; color: #92400e; }
.tha-di-err  { background: #fee2e2; color: #b91c1c; }
.tha-diag-title-txt { font-size: 13.5px; font-weight: 600; color: var(--qt2-primary); }
.tha-diag-body {
  padding: 12px 14px; font-size: 13px; color: var(--qt2-muted); line-height: 1.7;
