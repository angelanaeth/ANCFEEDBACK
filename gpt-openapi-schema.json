            "type": "object",
            "properties": {
              "days": {
                "type": "integer"
              },
              "planned_tss": {
                "type": "number"
              },
              "ctl": {
                "type": "number"
              },
              "atl": {
                "type": "number"
              },
              "tsb": {
                "type": "number"
              },
              "risk_assessment": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
