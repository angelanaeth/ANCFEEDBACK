{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=DB:angela-db --local --ip 0.0.0.0 --port 5000",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "wrangler d1 create angela-db",
    "db:migrate:local": "wrangler d1 migrations apply angela-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply angela-db",
    "clean-port": "fuser -k 5000/tcp 2>/dev/null || true",
    "git:init": "git init && git add . && git commit -m 'Initial commit'",
    "git:commit": "git add . && git commit -m"
  },
  "dependencies": {
    "hono": "^4.11.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}